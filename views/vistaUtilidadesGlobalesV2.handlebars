<script>
    let currentPage = 1;
    let currentFilters = {};
    let currentPageSize = 50;

    document.addEventListener('DOMContentLoaded', function() {
        // Inicializar Select2 en el dropdown de usuarios
        $('#selectUsuarios').select2({
            placeholder: 'Buscar y seleccionar usuarios...',
            allowClear: true,
            width: '100%',
            theme: 'bootstrap-5',
            language: {
                noResults: function() {
                    return "No se encontraron resultados";
                },
                searching: function() {
                    return "Buscando...";
                }
            }
        });

        // Eventos
        document.getElementById('filtrosForm').addEventListener('submit', function(e) {
            e.preventDefault();
            currentPage = 1;
            cargarDatos();
        });

        document.getElementById('btnLimpiarFiltros').addEventListener('click', function() {
            document.getElementById('filtrosForm').reset();
            $('#selectUsuarios').val(null).trigger('change'); // Limpiar Select2
            currentFilters = {};
            currentPage = 1;
            limpiarTabla();
        });

        document.getElementById('pageSize').addEventListener('change', function() {
            currentPageSize = parseInt(this.value);
            currentPage = 1;
            if (Object.keys(currentFilters).length > 0) {
                cargarDatos();
            }
        });

        document.getElementById('btnExportarExcel').addEventListener('click', function() {
            exportarExcel();
        });
    });

    function construirQueryParams(filtros, incluirPaginacion = true) {
        const params = new URLSearchParams();

        if (incluirPaginacion) {
            params.append('page', currentPage);
            params.append('limit', currentPageSize);
        }

        Object.entries(filtros || {}).forEach(([key, value]) => {
            if (key === 'usuarios') return;
            if (value !== undefined && value !== null && value !== '') {
                params.append(key, value);
            }
        });

        if (filtros.usuarios && Array.isArray(filtros.usuarios)) {
            filtros.usuarios.forEach(userId => {
                params.append('usuarios', userId);
            });
        }

        return params;
    }

    function obtenerFiltros() {
        const filtros = {};
        
        const fechaInicio = document.getElementById('fechaInicio').value;
        const fechaFin = document.getElementById('fechaFin').value;
        const idReserva = document.getElementById('idReserva').value.trim();
        const selectUsuarios = document.getElementById('selectUsuarios');
        const usuariosSeleccionados = Array.from(selectUsuarios.selectedOptions)
            .map(opt => opt.value)
            .filter(val => val !== '');

        if (fechaInicio) filtros.fechaInicio = fechaInicio;
        if (fechaFin) filtros.fechaFin = fechaFin;
        if (idReserva) filtros.idReserva = idReserva;
        if (usuariosSeleccionados.length > 0) filtros.usuarios = usuariosSeleccionados;

        return filtros;
    }

    async function cargarDatos() {
        try {
            currentFilters = obtenerFiltros();

            const params = construirQueryParams(currentFilters, true);

            mostrarCargando();

            const response = await fetch(`/api/utilidades-globales-json?${params.toString()}`);
            
            if (!response.ok) {
                throw new Error('Error al cargar los datos');
            }

            const data = await response.json();
            
            if (data.success) {
                renderizarTabla(data.data);
                renderizarPaginacion(data.pagination);
                actualizarResumen(data.pagination, data.summary);
            } else {
                throw new Error(data.error || 'Error desconocido');
            }

        } catch (error) {
            console.error('Error:', error);
            mostrarError(error.message);
        }
    }

    async function exportarExcel() {
        const btnExportar = document.getElementById('btnExportarExcel');
        const filtros = obtenerFiltros();
        const params = construirQueryParams(filtros, false);

        try {
            btnExportar.disabled = true;
            btnExportar.innerHTML = '<i class="fa fa-spinner fa-spin"></i> Exportando...';

            const response = await fetch(`/api/utilidades-globales-excel?${params.toString()}`);

            if (!response.ok) {
                let errorMessage = 'No se pudo exportar el archivo';
                try {
                    const errorData = await response.json();
                    errorMessage = errorData.error || errorMessage;
                } catch (e) {
                    // Mantener mensaje por defecto si no hay JSON
                }
                throw new Error(errorMessage);
            }

            const blob = await response.blob();
            const contentDisposition = response.headers.get('Content-Disposition') || '';
            const fileNameMatch = contentDisposition.match(/filename="?([^";]+)"?/i);
            const fileName = fileNameMatch ? fileNameMatch[1] : 'utilidades_globales_v2.xlsx';

            const url = window.URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = fileName;
            document.body.appendChild(a);
            a.click();
            a.remove();
            window.URL.revokeObjectURL(url);
        } catch (error) {
            console.error('Error al exportar Excel:', error);
            alert(error.message || 'Error al exportar Excel');
        } finally {
            btnExportar.disabled = false;
            btnExportar.innerHTML = '<i class="fa fa-file-excel"></i> Exportar Excel';
        }
    }

    function mostrarCargando() {
        const tbody = document.getElementById('tablaBody');
        tbody.innerHTML = `
            <tr>
                <td colspan="14" class="text-center">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Cargando...</span>
                    </div>
                    <p class="mt-2">Cargando datos...</p>
                </td>
            </tr>
        `;
    }

    function mostrarError(mensaje) {
        const tbody = document.getElementById('tablaBody');
        tbody.innerHTML = `
            <tr>
                <td colspan="14" class="text-center text-danger">
                    <i class="fa fa-exclamation-triangle fa-2x mb-2"></i>
                    <p>${mensaje}</p>
                </td>
            </tr>
        `;
    }

    function limpiarTabla() {
        const tbody = document.getElementById('tablaBody');
        tbody.innerHTML = `
            <tr>
                <td colspan="14" class="text-center">
                    <p class="mt-3 mb-3">Aplica filtros para cargar datos</p>
                </td>
            </tr>
        `;
        document.getElementById('totalRegistros').textContent = '0';
        document.getElementById('totalUtilidades').textContent = '$0.00';
        document.getElementById('paginaActual').textContent = '-';
        document.getElementById('pagination').innerHTML = '';
    }

    function renderizarTabla(utilidades) {
        const tbody = document.getElementById('tablaBody');
        
        if (!utilidades || utilidades.length === 0) {
            tbody.innerHTML = `
                <tr>
                    <td colspan="14" class="text-center">
                        <p class="mt-3 mb-3">No se encontraron resultados</p>
                    </td>
                </tr>
            `;
            return;
        }

        tbody.innerHTML = utilidades.map(u => {
            let statusClass = '';
            let statusText = u.statusReserva || 'N/A';
            
            switch(u.statusReserva) {
                case 'ACTIVE':
                    statusClass = 'text-success';
                    statusText = 'Activa';
                    break;
                case 'CANCELLED':
                    statusClass = 'text-danger';
                    statusText = 'Cancelada';
                    break;
                case 'PENDING':
                    statusClass = 'text-warning';
                    statusText = 'Pendiente';
                    break;
                case 'NO-SHOW':
                    statusClass = 'text-muted';
                    statusText = 'No Show';
                    break;
                case 'PLAYGROUND':
                    statusClass = 'text-info';
                    statusText = 'Playground';
                    break;
            }

            return `
                <tr>
                    <td>${u.nombreHabitacion || 'N/A'}</td>
                    <td>${u.chaletAdmin || 'N/A'}</td>
                    <td>${u.concepto || 'N/A'}</td>
                    <td>${u.idReserva || 'N/A'}</td>
                    <td>$${(u.monto || 0).toFixed(2)}</td>
                    <td>${u.nochesReservadas || 0}</td>
                    <td>${u.fecha || 'N/A'}</td>
                    <td>${u.checkOut || 'N/A'}</td>
                    <td class="${statusClass}">${statusText}</td>
                    <td>${u.nombreUsuario || 'N/A'}</td>
                    <td>${u.tipoUsuario || 'N/A'}</td>
                    <td>$${(u.totalReserva || 0).toFixed(2)}</td>
                    <td>$${(u.pagadoReserva || 0).toFixed(2)}</td>
                    <td>$${(u.restanteReserva || 0).toFixed(2)}</td>
                </tr>
            `;
        }).join('');
    }

    function renderizarPaginacion(pagination) {
        const paginationEl = document.getElementById('pagination');
        
        if (!pagination || pagination.totalPages <= 1) {
            paginationEl.innerHTML = '';
            return;
        }

        let html = '';

        // Botón anterior
        html += `
            <li class="page-item ${currentPage === 1 ? 'disabled' : ''}">
                <a class="page-link" href="#" onclick="cambiarPagina(${currentPage - 1}); return false;">
                    Anterior
                </a>
            </li>
        `;

        // Páginas
        const maxPagesToShow = 5;
        let startPage = Math.max(1, currentPage - Math.floor(maxPagesToShow / 2));
        let endPage = Math.min(pagination.totalPages, startPage + maxPagesToShow - 1);

        if (endPage - startPage < maxPagesToShow - 1) {
            startPage = Math.max(1, endPage - maxPagesToShow + 1);
        }

        if (startPage > 1) {
            html += `
                <li class="page-item">
                    <a class="page-link" href="#" onclick="cambiarPagina(1); return false;">1</a>
                </li>
            `;
            if (startPage > 2) {
                html += `<li class="page-item disabled"><span class="page-link">...</span></li>`;
            }
        }

        for (let i = startPage; i <= endPage; i++) {
            html += `
                <li class="page-item ${i === currentPage ? 'active' : ''}">
                    <a class="page-link" href="#" onclick="cambiarPagina(${i}); return false;">${i}</a>
                </li>
            `;
        }

        if (endPage < pagination.totalPages) {
            if (endPage < pagination.totalPages - 1) {
                html += `<li class="page-item disabled"><span class="page-link">...</span></li>`;
            }
            html += `
                <li class="page-item">
                    <a class="page-link" href="#" onclick="cambiarPagina(${pagination.totalPages}); return false;">
                        ${pagination.totalPages}
                    </a>
                </li>
            `;
        }

        // Botón siguiente
        html += `
            <li class="page-item ${currentPage === pagination.totalPages ? 'disabled' : ''}">
                <a class="page-link" href="#" onclick="cambiarPagina(${currentPage + 1}); return false;">
                    Siguiente
                </a>
            </li>
        `;

        paginationEl.innerHTML = html;
    }

    function cambiarPagina(page) {
        if (page < 1 || !currentFilters || Object.keys(currentFilters).length === 0) return;
        currentPage = page;
        cargarDatos();
        window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    function actualizarResumen(pagination, summary) {
        document.getElementById('totalRegistros').textContent = pagination.totalRecords.toLocaleString();
        document.getElementById('totalUtilidades').textContent = '$' + (summary.totalEarnings || 0).toFixed(2);
        document.getElementById('paginaActual').textContent = 
            `${pagination.currentPage} de ${pagination.totalPages}`;
    }
</script>
