<div class="container-fluid mt-4" style="width: 95%;">
    <div class="row">
        <div class="col-12">
            <h1 class="mb-4">Utilidades Globales v2</h1>
            
            <!-- Filtros -->
            <div class="card mb-4 bg-dark text-light">
                <div class="card-body">
                    <h5 class="card-title mb-3">Filtros de búsqueda</h5>
                    <form id="filtrosForm">
                        <div class="row g-3">
                            <!-- Fecha Inicio -->
                            <div class="col-md-2">
                                <label for="fechaInicio" class="form-label">Fecha Inicio:</label>
                                <input type="date" class="form-control bg-dark text-light" id="fechaInicio" name="fechaInicio">
                            </div>
                            
                            <!-- Fecha Fin -->
                            <div class="col-md-2">
                                <label for="fechaFin" class="form-label">Fecha Fin:</label>
                                <input type="date" class="form-control bg-dark text-light" id="fechaFin" name="fechaFin">
                            </div>
                            
                            <!-- Usuarios (múltiple) -->
                            <div class="col-md-3">
                                <label for="selectUsuarios" class="form-label">Usuarios:</label>
                                <select class="form-select bg-dark text-light" id="selectUsuarios" name="usuarios" multiple>
                                    {{#if usuarios}}
                                    {{#each usuarios}}
                                    <option value="{{this.id}}">{{this.nombre}}</option>
                                    {{/each}}
                                    {{/if}}
                                </select>
                                <small class="form-text text-muted">Busca y selecciona usuarios</small>
                            </div>
                            
                            <!-- ID Reserva -->
                            <div class="col-md-2">
                                <label for="idReserva" class="form-label">ID Reserva:</label>
                                <input type="text" class="form-control bg-dark text-light" id="idReserva" name="idReserva" placeholder="ID de reserva">
                            </div>
                            
                            <!-- Botones -->
                            <div class="col-md-3 d-flex flex-wrap align-items-end gap-2">
                                <button type="submit" class="btn btn-primary">
                                    <i class="fa fa-search"></i> Buscar
                                </button>
                                <button type="button" id="btnExportarExcel" class="btn btn-success text-nowrap">
                                    <i class="fa fa-file-excel"></i> Exportar Excel
                                </button>
                                <button type="button" id="btnLimpiarFiltros" class="btn btn-secondary">
                                    <i class="fa fa-eraser"></i> Limpiar
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Resumen -->
            <div class="card mb-4 bg-dark text-light">
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-4">
                            <h5>Total de registros:</h5>
                            <h3 id="totalRegistros">0</h3>
                        </div>
                        <div class="col-md-4">
                            <h5>Utilidades del período:</h5>
                            <h3 id="totalUtilidades">$0.00</h3>
                        </div>
                        <div class="col-md-4">
                            <h5>Página actual:</h5>
                            <h3 id="paginaActual">-</h3>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Tabla -->
            <div class="table-responsive">
                <table class="table table-dark table-hover text-center nowrap" id="tablaUtilidades">
                    <thead class="table-light">
                        <tr>
                            <th scope="col">Habitación</th>
                            <th scope="col">Admin Ligado</th>
                            <th scope="col">Concepto</th>
                            <th scope="col">ID Reserva</th>
                            <th scope="col">Monto</th>
                            <th scope="col">Noches</th>
                            <th scope="col">Check In</th>
                            <th scope="col">Check Out</th>
                            <th scope="col">Estatus</th>
                            <th scope="col">Usuario</th>
                            <th scope="col">Tipo Usuario</th>
                            <th scope="col">Total Reserva</th>
                            <th scope="col">Pagado</th>
                            <th scope="col">Pendiente</th>
                        </tr>
                    </thead>
                    <tbody id="tablaBody">
                        <tr>
                            <td colspan="14" class="text-center">
                                <p class="mt-3 mb-3">Aplica filtros para cargar datos</p>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <!-- Paginación -->
            <div class="d-flex justify-content-between align-items-center mt-3">
                <div>
                    <label for="pageSize" class="me-2">Registros por página:</label>
                    <select id="pageSize" class="form-select form-select-sm d-inline-block w-auto bg-dark text-light">
                        <option value="25">25</option>
                        <option value="50" selected>50</option>
                        <option value="100">100</option>
                        <option value="200">200</option>
                    </select>
                </div>
                
                <nav>
                    <ul class="pagination mb-0" id="pagination">
                        <!-- Se genera dinámicamente -->
                    </ul>
                </nav>
            </div>
        </div>
    </div>
</div>

<style>
