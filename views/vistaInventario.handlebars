<div id="inventoryGlobalSpinner" class="fixed top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 z-50 hidden">
    <div class="bg-white rounded-lg shadow-2xl p-4 border border-gray-200">
        <div class="flex items-center space-x-3">
            <div class="animate-spin rounded-full h-8 w-8 border-t-2 border-b-2 border-teal-500"></div>
            <p class="text-gray-900 text-sm font-medium">Cargando inventario...</p>
        </div>
    </div>
</div>

<div class="min-h-screen bg-gray-50 text-gray-800">
    <div class="bg-white border-b border-gray-200 px-4 py-4 sm:px-6 lg:px-8">
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
            <div>
                <h1 class="text-2xl sm:text-3xl font-bold text-gray-900">Inventario y BOM</h1>
                <p class="mt-1 text-sm text-gray-500">Control por habitacion, stock por bodega y consumo automatico por checkout</p>
            </div>
            <div class="flex flex-wrap gap-2">
                {{#if canManageInventory}}
                <button id="btn-open-warehouse" class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#modalWarehouse">
                    <i class="fas fa-warehouse me-1"></i> Nueva Bodega
                </button>
                <button id="btn-open-item" class="btn btn-success btn-sm" data-bs-toggle="modal" data-bs-target="#modalItem">
                    <i class="fas fa-boxes-stacked me-1"></i> Nuevo Item
                </button>
                <button id="btn-open-purchase" class="btn btn-success btn-sm" data-bs-toggle="modal" data-bs-target="#modalPurchase">
                    <i class="fas fa-cart-plus me-1"></i> Registrar Restock
                </button>
                <button id="btn-open-bom" class="btn btn-info btn-sm" data-bs-toggle="modal" data-bs-target="#modalBOMTemplate">
                    <i class="fas fa-list-check me-1"></i> Nueva BOM
                </button>
                {{/if}}
                {{#if canAdjustInventory}}
                <button id="btn-open-adjustment" class="btn btn-outline-dark btn-sm" data-bs-toggle="modal" data-bs-target="#modalAdjustment">
                    <i class="fas fa-sliders me-1"></i> Ajuste Manual
                </button>
                {{/if}}
                <button id="btn-run-checkout-consumption" class="btn btn-warning btn-sm {{#unless canManageInventory}}hidden{{/unless}}">
                    <i class="fas fa-play me-1"></i> Ejecutar Consumo Checkout
                </button>
            </div>
        </div>
    </div>

    <div class="bg-white border-b border-gray-200">
        <div class="px-4 sm:px-6 lg:px-8">
            <nav class="flex space-x-4 overflow-x-auto scrollbar-hide" aria-label="Tabs">
                {{#if canViewInventoryDashboard}}
                <button class="inventory-tab-button active whitespace-nowrap px-4 py-3 text-sm font-medium border-b-2 border-teal-500 text-teal-600" data-tab="dashboard">
                    <i class="fas fa-chart-pie me-1"></i> Dashboard
                </button>
                {{/if}}
                <button class="inventory-tab-button whitespace-nowrap px-4 py-3 text-sm font-medium {{#unless canViewInventoryDashboard}}active border-b-2 border-teal-500 text-teal-600{{else}}border-b-2 border-transparent text-gray-500 hover:text-gray-600 hover:border-gray-300{{/unless}}" data-tab="items">
                    <i class="fas fa-box me-1"></i> Items
                </button>
                <button class="inventory-tab-button whitespace-nowrap px-4 py-3 text-sm font-medium border-b-2 border-transparent text-gray-500 hover:text-gray-600 hover:border-gray-300" data-tab="warehouses">
                    <i class="fas fa-warehouse me-1"></i> Bodegas
                </button>
                <button class="inventory-tab-button whitespace-nowrap px-4 py-3 text-sm font-medium border-b-2 border-transparent text-gray-500 hover:text-gray-600 hover:border-gray-300" data-tab="room-inventory">
                    <i class="fas fa-bed me-1"></i> Inventario por Habitacion
                </button>
                <button class="inventory-tab-button whitespace-nowrap px-4 py-3 text-sm font-medium border-b-2 border-transparent text-gray-500 hover:text-gray-600 hover:border-gray-300" data-tab="bom">
                    <i class="fas fa-list-check me-1"></i> BOM
                </button>
                <button class="inventory-tab-button whitespace-nowrap px-4 py-3 text-sm font-medium border-b-2 border-transparent text-gray-500 hover:text-gray-600 hover:border-gray-300" data-tab="compras">
                    <i class="fas fa-cart-plus me-1"></i> Compras
                </button>
                <button class="inventory-tab-button whitespace-nowrap px-4 py-3 text-sm font-medium border-b-2 border-transparent text-gray-500 hover:text-gray-600 hover:border-gray-300" data-tab="kardex">
                    <i class="fas fa-clock-rotate-left me-1"></i> Kardex
                </button>
                <button class="inventory-tab-button whitespace-nowrap px-4 py-3 text-sm font-medium border-b-2 border-transparent text-gray-500 hover:text-gray-600 hover:border-gray-300" data-tab="alertas">
                    <i class="fas fa-bell me-1"></i> Alertas
                </button>
                {{#if canViewInventoryDashboard}}
                <button class="inventory-tab-button whitespace-nowrap px-4 py-3 text-sm font-medium border-b-2 border-transparent text-gray-500 hover:text-gray-600 hover:border-gray-300" data-tab="warehouse-summary">
                    <i class="fas fa-chart-column me-1"></i> Resumen de Bodegas
                </button>
                {{/if}}
            </nav>
        </div>
    </div>

    <div class="px-4 py-6 sm:px-6 lg:px-8">
        {{#if canViewInventoryDashboard}}
        <div id="inventory-tab-dashboard" class="inventory-tab-content active">
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
                <div class="bg-white rounded-lg p-6 shadow-lg border-l-4 border-teal-500">
                    <p class="text-gray-500 text-sm font-medium">Total Items</p>
                    <p id="dashboard-total-items" class="text-3xl font-bold text-gray-900 mt-2">0</p>
                </div>
                <div class="bg-white rounded-lg p-6 shadow-lg border-l-4 border-red-500">
                    <p class="text-gray-500 text-sm font-medium">Items Bajo Stock</p>
                    <p id="dashboard-low-stock" class="text-3xl font-bold text-red-600 mt-2">0</p>
                </div>
                <div class="bg-white rounded-lg p-6 shadow-lg border-l-4 border-indigo-500">
                    <p class="text-gray-500 text-sm font-medium">Ubicaciones con Inventario</p>
                    <p id="dashboard-room-count" class="text-3xl font-bold text-indigo-600 mt-2">0</p>
                </div>
                <div class="bg-white rounded-lg p-6 shadow-lg border-l-4 border-green-500">
                    <p class="text-gray-500 text-sm font-medium">Unidades Totales</p>
                    <p id="dashboard-total-units" class="text-3xl font-bold text-green-600 mt-2">0</p>
                </div>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
                <div class="bg-white rounded-lg p-6 shadow-xl">
                    <h3 class="text-lg font-semibold text-gray-900 mb-3">Stock por Ubicación</h3>
                    <div class="inventory-chart-shell mb-4">
                        <div class="inventory-chart-canvas-wrapper">
                            <canvas id="dashboard-stock-by-cabin-chart"></canvas>
                        </div>
                    </div>
                    <div id="stock-by-cabin" class="space-y-2"></div>
                </div>
                <div class="bg-white rounded-lg p-6 shadow-xl">
                    <h3 class="text-lg font-semibold text-gray-900 mb-3">Salud del Inventario</h3>
                    <div class="inventory-chart-shell mb-4">
                        <div class="inventory-chart-canvas-wrapper inventory-chart-canvas-wrapper--compact">
                            <canvas id="dashboard-stock-health-chart"></canvas>
                        </div>
                    </div>
                    <div id="critical-items" class="space-y-2 max-h-80 overflow-y-auto"></div>
                </div>
            </div>
        </div>
        {{/if}}

        <div id="inventory-tab-items" class="inventory-tab-content {{#if canViewInventoryDashboard}}hidden{{else}}active{{/if}}">
            <div class="bg-white rounded-lg p-6 shadow-xl">
                <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-4">
                    <h3 class="text-lg font-semibold text-gray-900">Listado de Items</h3>
                    <button id="btn-refresh-items" class="btn btn-outline-secondary btn-sm"><i class="fas fa-rotate me-1"></i>Actualizar</button>
                </div>
                <div class="overflow-x-auto">
                    <table class="table table-sm table-striped align-middle">
                        <thead>
                            <tr>
                                <th>Item</th>
                                <th>No. parte</th>
                                <th>Tipo</th>
                                <th>Unidad</th>
                                <th>Stock</th>
                                <th>Min</th>
                                <th>Ubicación</th>
                                <th>Acciones</th>
                            </tr>
                        </thead>
                        <tbody id="items-table-body"></tbody>
                    </table>
                </div>
            </div>
        </div>

        <div id="inventory-tab-warehouses" class="inventory-tab-content hidden">
            <div class="bg-white rounded-lg p-6 shadow-xl">
                <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-4">
                    <h3 class="text-lg font-semibold text-gray-900">Bodegas por Habitacion</h3>
                    <button id="btn-refresh-warehouses" class="btn btn-outline-secondary btn-sm"><i class="fas fa-rotate me-1"></i>Actualizar</button>
                </div>
                <div class="rounded border border-sky-200 bg-sky-50 p-3 mb-4">
                    <p class="text-sm font-semibold text-sky-800 mb-1">Asignacion exclusiva</p>
                    <p class="text-xs text-sky-700 mb-0">Cada habitacion solo puede pertenecer a una bodega activa. La bodega habilita el consumo automatico en checkout cuando tambien existe una BOM vigente.</p>
                </div>
                <div id="warehouses-list" class="space-y-3"></div>
            </div>
        </div>

        <div id="inventory-tab-room-inventory" class="inventory-tab-content hidden">
            <div class="bg-white rounded-lg p-6 shadow-xl">
                <div class="flex flex-col lg:flex-row lg:items-start lg:justify-between gap-4 mb-5">
                    <div>
                        <h3 class="text-lg font-semibold text-gray-900 mb-1">Inventario Manual por Habitacion</h3>
                        <p class="text-sm text-gray-500 mb-0">Este flujo aplica solo a items indirectos y no consumibles. El checkout automatico sigue descontando solo items directos desde la bodega.</p>
                    </div>
                    <div class="flex flex-wrap gap-2">
                        {{#if canAdjustInventory}}
                        <button id="btn-open-room-transfer" class="btn btn-primary btn-sm">
                            <i class="fas fa-right-left me-1"></i> Transferir a Habitacion
                        </button>
                        <button id="btn-open-room-adjustment" class="btn btn-outline-dark btn-sm">
                            <i class="fas fa-screwdriver-wrench me-1"></i> Ajustar Habitacion
                        </button>
                        {{/if}}
                        <button id="btn-refresh-room-inventory" class="btn btn-outline-secondary btn-sm">
                            <i class="fas fa-rotate me-1"></i>Actualizar
                        </button>
                    </div>
                </div>

                <div class="grid grid-cols-1 lg:grid-cols-[280px,1fr] gap-5">
                    <div class="space-y-4">
                        <div class="border border-gray-200 rounded-xl p-4 bg-gray-50">
                            <label class="text-sm font-medium text-gray-700 mb-1">Habitacion</label>
                            <select id="room-inventory-room-select" class="form-select mb-3">
                                <option value="">Selecciona habitacion</option>
                            </select>
                            <label class="text-sm font-medium text-gray-700 mb-1">Tipo de item</label>
                            <select id="room-inventory-type-filter" class="form-select">
                                <option value="all">Todos</option>
                                <option value="indirecto">Indirecto</option>
                                <option value="no_consumible">No consumible</option>
                            </select>
                        </div>

                        <div class="border border-sky-200 bg-sky-50 rounded-xl p-4">
                            <p class="text-sm font-semibold text-sky-800 mb-1">Como funciona</p>
                            <p class="text-xs text-sky-700 mb-1">1. El item nace y se compra en la bodega.</p>
                            <p class="text-xs text-sky-700 mb-1">2. Se transfiere manualmente a una habitacion de esa misma bodega.</p>
                            <p class="text-xs text-sky-700 mb-0">3. La habitacion puede ajustarse manualmente sin tocar la BOM.</p>
                        </div>
                    </div>

                    <div>
                        <div id="room-inventory-loading" class="hidden room-inventory-loading mb-4">
                            <div class="room-inventory-loading__box">
                                <div class="animate-spin rounded-full h-7 w-7 border-t-2 border-b-2 border-teal-500"></div>
                                <p class="text-sm font-medium text-gray-700 mb-0">Cargando inventario de la habitacion...</p>
                            </div>
                        </div>
                        <div id="room-inventory-summary" class="grid grid-cols-1 md:grid-cols-3 gap-3 mb-4"></div>
                        <div class="overflow-x-auto">
                            <table class="table table-sm table-striped align-middle">
                                <thead>
                                    <tr>
                                        <th>Item</th>
                                        <th>No. parte</th>
                                        <th>Tipo</th>
                                        <th>Unidad</th>
                                        <th>Stock Bodega</th>
                                        <th>Stock Habitacion</th>
                                        <th>Ult. actualizacion</th>
                                        <th>Acciones</th>
                                    </tr>
                                </thead>
                                <tbody id="room-inventory-table-body">
                                    <tr>
                                        <td colspan="8" class="text-center text-gray-500">Selecciona una habitacion para consultar su inventario.</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div id="inventory-tab-bom" class="inventory-tab-content hidden">
            <div class="bg-white rounded-lg p-6 shadow-xl">
                <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-4">
                    <h3 class="text-lg font-semibold text-gray-900">Plantillas BOM</h3>
                    <button id="btn-refresh-bom" class="btn btn-outline-secondary btn-sm"><i class="fas fa-rotate me-1"></i>Actualizar</button>
                </div>
                <div id="bom-list" class="space-y-3"></div>
            </div>
        </div>

        <div id="inventory-tab-compras" class="inventory-tab-content hidden">
            <div class="bg-white rounded-lg p-6 shadow-xl">
                <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-4">
                    <h3 class="text-lg font-semibold text-gray-900">Historial de Compras y Restock</h3>
                    <button id="btn-refresh-purchases" class="btn btn-outline-secondary btn-sm"><i class="fas fa-rotate me-1"></i>Actualizar</button>
                </div>
                <div class="overflow-x-auto">
                    <table class="table table-sm table-striped align-middle">
                        <thead>
                            <tr>
                                <th>Fecha</th>
                                <th>Ubicación</th>
                                <th>Proveedor</th>
                                <th>Factura</th>
                                <th>Items</th>
                                <th>Total</th>
                            </tr>
                        </thead>
                        <tbody id="purchases-table-body"></tbody>
                    </table>
                </div>
            </div>
        </div>

        <div id="inventory-tab-kardex" class="inventory-tab-content hidden">
            <div class="bg-white rounded-lg p-6 shadow-xl">
                <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-4">
                    <h3 class="text-lg font-semibold text-gray-900">Kardex / Movimientos</h3>
                    <button id="btn-refresh-movements" class="btn btn-outline-secondary btn-sm"><i class="fas fa-rotate me-1"></i>Actualizar</button>
                </div>
                <div class="overflow-x-auto">
                    <table class="table table-sm table-striped align-middle">
                        <thead>
                            <tr>
                                <th>Fecha</th>
                                <th>Tipo</th>
                                <th>Item</th>
                                <th>Ubicación</th>
                                <th>Cantidad</th>
                                <th>Costo</th>
                                <th>Antes</th>
                                <th>Despues</th>
                                <th>Nota</th>
                            </tr>
                        </thead>
                        <tbody id="movements-table-body"></tbody>
                    </table>
                </div>
            </div>
        </div>

        <div id="inventory-tab-alertas" class="inventory-tab-content hidden">
            <div class="bg-white rounded-lg p-6 shadow-xl">
                <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-4">
                    <h3 class="text-lg font-semibold text-gray-900">Alertas de Inventario</h3>
                    <button id="btn-refresh-alerts" class="btn btn-outline-secondary btn-sm"><i class="fas fa-rotate me-1"></i>Actualizar</button>
                </div>
                <div id="alerts-list" class="space-y-3"></div>
            </div>
        </div>

        {{#if canViewInventoryDashboard}}
        <div id="inventory-tab-warehouse-summary" class="inventory-tab-content hidden">
            <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-4 mb-6">
                <div class="bg-white rounded-lg p-5 shadow-lg border-l-4 border-sky-500">
                    <p class="text-gray-500 text-sm font-medium">Bodegas Activas</p>
                    <p id="warehouse-summary-total-warehouses" class="text-3xl font-bold text-gray-900 mt-2">0</p>
                </div>
                <div class="bg-white rounded-lg p-5 shadow-lg border-l-4 border-emerald-500">
                    <p class="text-gray-500 text-sm font-medium">Items Registrados</p>
                    <p id="warehouse-summary-total-items" class="text-3xl font-bold text-gray-900 mt-2">0</p>
                </div>
                <div class="bg-white rounded-lg p-5 shadow-lg border-l-4 border-amber-500">
                    <p class="text-gray-500 text-sm font-medium">Stock Total</p>
                    <p id="warehouse-summary-total-stock" class="text-3xl font-bold text-gray-900 mt-2">0</p>
                </div>
                <div class="bg-white rounded-lg p-5 shadow-lg border-l-4 border-rose-500">
                    <p class="text-gray-500 text-sm font-medium">Items Bajo Stock</p>
                    <p id="warehouse-summary-low-stock" class="text-3xl font-bold text-gray-900 mt-2">0</p>
                </div>
            </div>

            <div class="bg-white rounded-lg p-6 shadow-xl mb-6">
                <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-4">
                    <h3 class="text-lg font-semibold text-gray-900">Resumen Operativo de Bodegas</h3>
                    <button id="btn-refresh-warehouse-summary" class="btn btn-outline-secondary btn-sm"><i class="fas fa-rotate me-1"></i>Actualizar</button>
                </div>
                <p class="text-xs text-gray-500 mb-4">Cada tarjeta muestra habitaciones, estado BOM e items registrados en la bodega.</p>
                <div id="warehouse-visual-summary" class="grid grid-cols-1 xl:grid-cols-2 gap-5 mb-2"></div>
            </div>

            <div class="bg-white rounded-lg p-6 shadow-xl mb-6">
                <div class="flex items-center justify-between gap-3 mb-4">
                    <h4 class="text-base font-semibold text-gray-900 mb-0">Vista Tabular</h4>
                    <span class="text-xs text-gray-500">Referencia rapida</span>
                </div>
                <div class="overflow-x-auto">
                    <table class="table table-sm table-striped align-middle">
                        <thead>
                            <tr>
                                <th>Bodega</th>
                                <th>Habitaciones</th>
                                <th>Items</th>
                                <th>Stock</th>
                                <th>Con BOM</th>
                                <th>Sin BOM</th>
                            </tr>
                        </thead>
                        <tbody id="warehouse-summary-table-body"></tbody>
                    </table>
                </div>
            </div>
        </div>
        {{/if}}
    </div>
</div>

<div class="modal fade" id="modalWarehouse" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modal-warehouse-title">Nueva Bodega</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form id="form-warehouse">
                <div class="modal-body space-y-3">
                    <input class="form-control" name="name" placeholder="Nombre de la bodega" required>
                    <textarea class="form-control" name="description" placeholder="Descripcion opcional"></textarea>
                    <div>
                        <div class="flex items-center justify-between mb-1">
                            <label class="text-sm font-medium text-gray-700 mb-0">Habitaciones</label>
                            <span class="text-xs text-gray-500">Selecciona una o varias</span>
                        </div>
                        <p class="text-xs text-gray-500 mb-2">Cada habitacion solo puede estar en una bodega activa. Si una habitacion no pertenece a una bodega, su checkout no descontara stock de la BOM.</p>
                        <input id="warehouse-room-filter" type="text" class="form-control form-control-sm mb-2" placeholder="Filtrar habitaciones...">
                        <div id="warehouse-room-checklist" class="bom-room-checklist"></div>
                    </div>
                    <p class="text-xs text-gray-500">Las bodegas agrupan habitaciones y concentran los items que se consumen desde esas habitaciones.</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-primary" id="modal-warehouse-submit">Guardar</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="modalItem" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modal-item-title">Nuevo Item</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form id="form-item">
                <div class="modal-body space-y-3">
                    <input class="form-control" name="name" placeholder="Nombre del item" required>
                    <input class="form-control" name="partNumber" placeholder="Numero de parte (opcional)">
                    <textarea class="form-control" name="description" placeholder="Descripción"></textarea>
                    <select class="form-select" name="itemType" required>
                        <option value="directo">Directo</option>
                        <option value="indirecto">Indirecto</option>
                        <option value="no_consumible">No consumible</option>
                    </select>
                    <select class="form-select" name="unit" id="item-unit-select" required>
                        <option value="">Selecciona unidad</option>
                        <option value="pz">Pieza (pz)</option>
                        <option value="juego">Juego</option>
                        <option value="par">Par</option>
                        <option value="rollo">Rollo</option>
                        <option value="paquete">Paquete</option>
                        <option value="caja">Caja</option>
                        <option value="bolsa">Bolsa</option>
                        <option value="botella">Botella</option>
                        <option value="lata">Lata</option>
                        <option value="lt">Litro (lt)</option>
                        <option value="ml">Mililitro (ml)</option>
                        <option value="kg">Kilogramo (kg)</option>
                        <option value="g">Gramo (g)</option>
                        <option value="otra">Otra...</option>
                    </select>
                    <input class="form-control hidden" name="unitCustom" id="item-unit-custom" placeholder="Especifica unidad personalizada">

                    <div class="rounded border border-sky-200 bg-sky-50 p-3">
                        <p class="text-sm font-semibold text-sky-800 mb-1">Bodega del item</p>
                        <p class="text-xs text-sky-700 mb-0">Cada item pertenece a una sola bodega. El stock, compras, ajustes y checkout se controlan dentro de esa bodega.</p>
                    </div>

                    <div>
                        <label class="text-sm font-medium text-gray-700 mb-1">Bodega</label>
                        <select class="form-select" name="warehouse" id="item-warehouse-select" required>
                            <option value="">Selecciona bodega</option>
                        </select>
                    </div>

                    <div>
                        <label class="text-sm font-medium text-gray-700 mb-1">Stock inicial</label>
                        <input type="number" min="0" step="0.01" class="form-control" name="stockCurrent" placeholder="Ej. 25" value="0">
                        <p class="text-xs text-gray-500 mt-1 mb-0">Si capturas stock inicial, registra tambien el costo unitario de esa primera compra.</p>
                    </div>

                    <div>
                        <label class="text-sm font-medium text-gray-700 mb-1">Stock mínimo (alerta)</label>
                        <input type="number" min="0" step="0.01" class="form-control" name="stockMin" placeholder="Ej. 5" value="0">
                        <p class="text-xs text-gray-500 mt-1 mb-0">Cuando el stock llegue a este valor, se generará alerta de reposición.</p>
                    </div>

                    <div id="item-initial-purchase-section" class="border border-emerald-200 bg-emerald-50 rounded p-3 space-y-3">
                        <div>
                            <p class="text-sm font-semibold text-emerald-800 mb-1">Compra inicial</p>
                            <p class="text-xs text-emerald-700 mb-0">Estos datos se usan para dejar trazado el primer lote del item al momento de crearlo.</p>
                        </div>

                        <div>
                            <label class="text-sm font-medium text-gray-700 mb-1">Costo unitario inicial</label>
                            <input type="number" min="0" step="0.01" class="form-control" name="initialUnitCost" id="item-initial-unit-cost" placeholder="Ej. 18.50">
                        </div>

                        <div>
                            <label class="text-sm font-medium text-gray-700 mb-1">Proveedor</label>
                            <input class="form-control" name="initialSupplier" placeholder="Opcional">
                        </div>

                        <div>
                            <label class="text-sm font-medium text-gray-700 mb-1">Factura / referencia</label>
                            <input class="form-control" name="initialInvoiceNumber" placeholder="Opcional">
                        </div>

                        <div>
                            <label class="text-sm font-medium text-gray-700 mb-1">Fecha de compra inicial</label>
                            <input type="date" class="form-control" name="initialPurchaseDate">
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-success" id="modal-item-submit">Guardar</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="modalBOMTemplate" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modal-bom-title">Nueva Regla de Consumo BOM</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form id="form-bom-template">
                <div class="modal-body bom-modal-body">
                    <div class="bom-modal-grid">
                        <section class="bom-panel">
                            <h6 class="bom-panel-title">Configuración</h6>
                            <div class="space-y-3">
                                <input class="form-control" name="name" placeholder="Nombre de la regla BOM" required>
                                <div>
                                    <label class="text-sm font-medium text-gray-700 mb-1">Vigente desde</label>
                                    <input type="datetime-local" class="form-control" name="effectiveFrom" id="bom-effective-from" required>
                                    <p class="text-xs text-gray-500 mt-1 mb-0">Solo se aplicará a reservas creadas a partir de esta fecha y hora.</p>
                                </div>
                            </div>

                            <div class="mt-4">
                                <div class="flex items-center justify-between mb-1">
                                    <label class="text-sm font-medium text-gray-700 mb-0">Habitaciones</label>
                                    <span class="text-xs text-gray-500">Selecciona una o varias</span>
                                </div>
                                <p class="text-xs text-gray-500 mb-2">Si eliges varias, se crea una regla individual por cada habitación. No se comparte una sola regla entre ellas.</p>
                                <input id="bom-room-filter" type="text" class="form-control form-control-sm mb-2" placeholder="Filtrar habitaciones...">
                                <div id="bom-room-checklist" class="bom-room-checklist"></div>
                            </div>
                        </section>

                        <section class="bom-panel">
                            <div class="flex items-center justify-between mb-2">
                                <h6 class="bom-panel-title mb-0">Consumo por Noche</h6>
                                <button id="btn-add-bom-line" type="button" class="btn btn-outline-primary btn-sm">Agregar producto</button>
                            </div>
                            <div class="bg-blue-50 border border-blue-200 rounded p-2 mb-3 text-xs text-blue-800 space-y-1">
                                <p class="mb-0"><strong>Cantidad por noche:</strong> consumo base del producto por cada noche de la reserva.</p>
                                <p class="mb-0"><strong>Factor:</strong> multiplicador del consumo base (1 = normal, 2 = doble, 0.5 = mitad).</p>
                                <p class="mb-0">Ejemplo: Si "Toalla" tiene cantidad 2 y factor 1.5, en una reserva de 3 noches se descuentan 2 x 1.5 x 3 = 9 toallas.</p>
                            </div>
                            <div id="bom-lines-container" class="space-y-2"></div>
                        </section>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-info" id="modal-bom-submit">Guardar BOM</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="modalPurchase" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Registrar Compra / Restock</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form id="form-purchase">
                <div class="modal-body space-y-3">
                    <div class="grid md:grid-cols-2 gap-3">
                        <select class="form-select" name="warehouse" id="purchase-warehouse-select" required>
                            <option value="">Selecciona bodega</option>
                        </select>
                        <input type="date" class="form-control" name="purchaseDate">
                    </div>
                    <div class="grid md:grid-cols-2 gap-3">
