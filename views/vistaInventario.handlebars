                    </div>
                    <div class="border border-emerald-200 bg-emerald-50 rounded p-3">
                        <div class="flex items-center justify-between mb-2">
                            <h6 class="font-semibold text-emerald-800 mb-0">Lineas de compra</h6>
                            <button id="btn-add-purchase-line" type="button" class="btn btn-outline-success btn-sm">Agregar item</button>
                        </div>
                        <div id="purchase-lines-container" class="space-y-2"></div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-success">Registrar compra</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="modalAdjustment" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Ajuste Manual de Inventario</h5>
