<div class="calendar-header">
    <div class="bg-dark mb-3">
        <a name="" id="crear-reserva-dueno-btn" class="btn btn-secondary btn-sm m-3" href="#" role="button"
            data-bs-toggle="modal" data-bs-target="#owner_entry_modal">Apartar fechas</a>
        {{#if (eq privilege 'Inversionistas')}}
        <a name="" id="crear-reserva-inversionista-btn" class="btn btn-success btn-sm m-3" href="#" role="button"
            data-bs-toggle="modal" data-bs-target="#event_entry_modal">Crear reserva inversionista</a>
        {{/if}}
    </div>
</div>

<div class="row flex-nowrap justify-content-center mt-3 " style="width: 100%;">
    <div class="col-10">
        <h1>Reservas</h1>
        <div class="table-responsive">

            <table class="table table-dark table-hover text-center" id="tablaParaDuenos">
                <thead class="table-light">
                    <tr>
                        <th scope="col">Cabaña</th>
                        <th scope="col">Fecha de llegada</th>
                        <th scope="col">Fecha de salida</th>
                    </tr>
                </thead>
                <tbody>
                    {{#if eventos.length}}
                    {{#each eventos}}
                    <tr>
                        <td>{{this.roomName}}</td>
                        <td>{{this.arrivalDate}}</td>
                        <td>{{this.departureDate}}</td>
                    </tr>
                    {{/each}}
                    {{else}}
                        <tr>
                            <td colspan="3">No se encontraron servicios</td>
                            <td style="display: none;"></td>
                            <td style="display: none;"></td>
                        </tr>
                    {{/if}}
                </tbody>
            </table>
        </div>
    </div>
</div>

{{#if (eq privilege 'Inversionistas')}}
    <a name="" id="" class="btn btn-primary mt-5" href="/api/cabanas/ownercalendar" role="button">Cambiar a vista de calendario</a>
{{else if (eq privilege 'Colaborador dueño')}}
    <a name="" id="" class="btn btn-primary mt-5" href="/api/cabanas/ownercalendar" role="button">Cambiar a vista de calendario</a>
{{/if}}

<style>
    .modal-reserva {
        border: none;
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 20px 60px rgba(126, 206, 197, 0.3);
    }

    .modal-header-mint {
        background: linear-gradient(135deg, #7ECEC5 0%, #5FBFB3 100%);
        color: white;
        border: none;
        padding: 1.25rem 1.5rem;
    }

    .modal-body-reserva {
        padding: 1.5rem;
        background: #fafcfb;
        max-height: 70vh;
        overflow-y: auto;
    }

    .reservation-section {
        background: white;
        border-radius: 12px;
        padding: 1.25rem;
        margin-bottom: 1rem;
        box-shadow: 0 2px 8px rgba(0,0,0,0.04);
        border: 1px solid #f0f0f0;
    }

    .section-header {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin-bottom: 1rem;
        padding-bottom: 0.75rem;
        border-bottom: 2px solid #E8F6F4;
    }

    .section-header h6 { margin: 0; }

    .reservation-steps {
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 1.5rem;
        padding: 1rem;
        background: white;
        border-radius: 12px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.05);
    }

    .step { display: flex; flex-direction: column; align-items: center; opacity: 0.5; }
    .step.active, .step.completed { opacity: 1; }
    .step-number {
        width: 32px; height: 32px; border-radius: 50%; background: #e0e0e0; color: #666;
        display: flex; align-items: center; justify-content: center; font-weight: 600;
    }
    .step.active .step-number, .step.completed .step-number { background: #7ECEC5; color: #fff; }
    .step-line { width: 40px; height: 2px; background: #e0e0e0; margin: 0 0.5rem 1rem 0.5rem; }
</style>

<!-- Modal Apartar Fechas -->
<div class="modal fade" id="owner_entry_modal" tabindex="-1" role="dialog" aria-labelledby="ownerModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="ownerModalLabel">Apartar fechas</h5>
                <button type="button" class="close" onclick="$('#owner_entry_modal').modal('hide');" aria-label="Close">&times;</button>
            </div>
            <div class="modal-body">
                <div class="row mt-2">
                    <div class="col-sm-6">
                        <label for="owner_cliente_name">Nombre de cliente</label>
                        <input type="text" id="owner_cliente_name" class="form-control" placeholder="Nombre">
                    </div>
                </div>
                <div class="row mt-2">
                    <div class="col-sm-6">
                        <label for="owner_date_range">Rango de fechas</label>
                        <input type="text" id="owner_date_range" class="form-control" placeholder="Selecciona un rango de fechas">
                        <input type="hidden" id="owner_event_start_date">
                        <input type="hidden" id="owner_event_end_date">
                    </div>
                    <div class="col-sm-3">
                        <label for="owner_event_nights">Noches</label>
                        <input type="number" id="owner_event_nights" class="form-control" min="1" disabled>
                    </div>
                </div>
                <div class="row mt-3">
                    <div class="col-sm-6">
                        <p id="owner_verificar_disponibilidad" style="display:none;">Verificando disponibilidad...</p>
                        <label for="owner_tipologia_habitacion">Habitación</label>
                        <select id="owner_tipologia_habitacion" class="form-select" required>
                            <option value="" selected disabled>Selecciona una cabaña</option>
                            {{#if chalets}}
                                {{#each chalets}}
                                <option value="{{this.propertyDetails.name}}" data-bs-pax="{{this.propertyDetails.maxOccupancy}}" data-bs-id="{{this._id}}">
                                    {{this.propertyDetails.name}}
                                </option>
                                {{/each}}
                            {{/if}}
                        </select>
                        <input type="hidden" id="owner_id_cabana">
                    </div>
                    <div class="col-sm-3">
                        <label for="owner_ocupacion_habitacion">Ocupación Máx.</label>
                        <input type="number" id="owner_ocupacion_habitacion" class="form-control" readonly>
                    </div>
                </div>
                <p id="owner_txtReservationError" class="error mt-2"></p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-primary" id="save-owner-event-btn">Crear Reserva</button>
            </div>
        </div>
    </div>
</div>

{{#if (eq privilege 'Inversionistas')}}
<div class="loader loader--hidden"></div>
<div class="modal fade" id="event_entry_modal" tabindex="-1" role="dialog" aria-labelledby="modalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content modal-reserva">
            <div class="modal-header modal-header-mint">
                <h5 class="modal-title" id="modalLabel"><i class="fa fa-calendar-plus"></i> Nueva Reserva Inversionista</h5>
                <button type="button" class="close text-white" onclick="$('#event_entry_modal').modal('hide');" aria-label="Close">&times;</button>
            </div>
            <div class="modal-body modal-body-reserva">
                <div class="reservation-steps">
                    <div class="step active" data-step="1"><div class="step-number">1</div><span>Cliente</span></div>
                    <div class="step-line"></div>
                    <div class="step" data-step="2"><div class="step-number">2</div><span>Fechas</span></div>
                    <div class="step-line"></div>
                    <div class="step" data-step="3"><div class="step-number">3</div><span>Habitación</span></div>
                    <div class="step-line"></div>
                    <div class="step" data-step="4"><div class="step-number">4</div><span>Confirmar</span></div>
                </div>

                <div class="reservation-section" id="section-cliente">
                    <div class="section-header"><i class="fa fa-user"></i><h6>Información del cliente</h6></div>
                    <div class="row g-3 mb-3">
