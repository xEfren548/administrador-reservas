<div class="calendar-header">
    <div class="bg-dark mb-3">
        <a name="" id="crear-reserva-dueno-btn" class="btn btn-secondary btn-sm m-3" href="#" role="button"
            data-bs-toggle="modal" data-bs-target="#owner_entry_modal">Apartar fechas</a>
    </div>
</div>

<div class="row flex-nowrap justify-content-center mt-3 " style="width: 100%;">
    <div class="col-10">
        <h1>Reservas</h1>
        <div class="table-responsive">
            <table class="table table-dark table-hover text-center" id="tablaParaDuenos">
                <thead class="table-light">
                    <tr>
                        <th scope="col">Cabaña</th>
                        <th scope="col">Fecha de llegada</th>
                        <th scope="col">Fecha de salida</th>
                    </tr>
                </thead>
                <tbody>
                    {{#if eventos.length}}
                    {{#each eventos}}
                    <tr>
                        <td>{{this.roomName}}</td>
                        <td>{{this.arrivalDate}}</td>
                        <td>{{this.departureDate}}</td>
                    </tr>
                    {{/each}}
                    {{else}}
                        <tr>
                            <td colspan="3">No se encontraron servicios</td>
                            <td style="display: none;"></td>
                            <td style="display: none;"></td>
                        </tr>
                    {{/if}}
                </tbody>
            </table>
        </div>
    </div>
</div>

{{#if (eq privilege 'Inversionistas')}}
    <a name="" id="" class="btn btn-primary mt-5" href="/api/cabanas/ownercalendar" role="button">Cambiar a vista de calendario</a>
{{else if (eq privilege 'Colaborador dueño')}}
    <a name="" id="" class="btn btn-primary mt-5" href="/api/cabanas/ownercalendar" role="button">Cambiar a vista de calendario</a>
{{/if}}

<div class="modal fade" id="owner_entry_modal" tabindex="-1" role="dialog" aria-labelledby="ownerModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="ownerModalLabel">Apartar fechas</h5>
                <button type="button" class="close" onclick="$('#owner_entry_modal').modal('hide');" aria-label="Close">&times;</button>
            </div>
            <div class="modal-body">
                <div class="row mt-2">
                    <div class="col-sm-6">
                        <label for="owner_cliente_name">Nombre de cliente</label>
                        <input type="text" id="owner_cliente_name" class="form-control" placeholder="Nombre">
                    </div>
                </div>
                <div class="row mt-2">
                    <div class="col-sm-6">
                        <label for="owner_date_range">Rango de fechas</label>
                        <input type="text" id="owner_date_range" class="form-control" placeholder="Selecciona un rango de fechas">
                        <input type="hidden" id="owner_event_start_date">
                        <input type="hidden" id="owner_event_end_date">
                    </div>
                    <div class="col-sm-3">
                        <label for="owner_event_nights">Noches</label>
                        <input type="number" id="owner_event_nights" class="form-control" min="1" disabled>
                    </div>
                </div>
                <div class="row mt-3">
                    <div class="col-sm-6">
                        <p id="owner_verificar_disponibilidad" style="display:none;">Verificando disponibilidad...</p>
                        <label for="owner_tipologia_habitacion">Habitación</label>
                        <select id="owner_tipologia_habitacion" class="form-select" required>
                            <option value="" selected disabled>Selecciona una cabaña</option>
                            {{#if chalets}}
                                {{#each chalets}}
                                <option value="{{this.propertyDetails.name}}" data-bs-pax="{{this.propertyDetails.maxOccupancy}}" data-bs-id="{{this._id}}">
                                    {{this.propertyDetails.name}}
                                </option>
                                {{/each}}
                            {{/if}}
                        </select>
                        <input type="hidden" id="owner_id_cabana">
                    </div>
                    <div class="col-sm-3">
                        <label for="owner_ocupacion_habitacion">Ocupación Máx.</label>
                        <input type="number" id="owner_ocupacion_habitacion" class="form-control" readonly>
                    </div>
                </div>
                <p id="owner_txtReservationError" class="error mt-2"></p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-primary" id="save-owner-event-btn">Crear Reserva</button>
            </div>
        </div>
    </div>
</div>

<script>
    async function cancelarReserva(id) {
        const confirmacion = await Swal.fire({
            title: 'Advertencia',
            text: 'Esta acción liberará las fechas de la reserva.',
            icon: 'warning',
            showCancelButton: true
        });

        if (!confirmacion.isConfirmed) return;

        const response = await fetch(`/api/eventos/${id}`, {
            method: 'DELETE',
            headers: { 'Content-Type': 'application/json' }
        });

        if (response.ok) {
            Swal.fire({
                icon: 'success',
                title: '¡Completado!',
                text: 'Reserva eliminada correctamente.',
                confirmButtonText: 'Aceptar'
            }).then(() => window.location.reload());
        }
    }

    document.addEventListener('DOMContentLoaded', function () {
        const table = document.getElementById('tablaParaDuenos');
        if (table) {
            new DataTable(table, {
                order: [],
                paging: true,
                lengthMenu: [5, 10, 25, 50],
                pageLength: 10
            });
        }

        const ownerDateRange = document.getElementById('owner_date_range');
        const ownerStart = document.getElementById('owner_event_start_date');
        const ownerEnd = document.getElementById('owner_event_end_date');
        const ownerNights = document.getElementById('owner_event_nights');
        const ownerRoomSelect = document.getElementById('owner_tipologia_habitacion');
        const ownerOccInput = document.getElementById('owner_ocupacion_habitacion');
        const ownerRoomIdInput = document.getElementById('owner_id_cabana');
        const ownerAvailability = document.getElementById('owner_verificar_disponibilidad');

        if (ownerDateRange) {
            flatpickr('#owner_date_range', {
                mode: 'range',
                dateFormat: 'd-m-Y',
                onChange: async function (selectedDates) {
                    if (selectedDates.length !== 2) return;
                    ownerStart.value = selectedDates[0].toISOString().split('T')[0];
                    ownerEnd.value = selectedDates[1].toISOString().split('T')[0];

                    const nights = Math.ceil((selectedDates[1].getTime() - selectedDates[0].getTime()) / (1000 * 3600 * 24));
                    ownerNights.value = nights > 0 ? nights : 0;

                    if (!ownerRoomSelect) return;
                    ownerAvailability.style.display = 'block';
                    ownerRoomSelect.disabled = true;

                    try {
                        const options = ownerRoomSelect.querySelectorAll('option[data-bs-id]');
                        const arrivalDate = ownerStart.value;
                        const departureDate = ownerEnd.value;

                        for (const option of options) {
                            const roomId = option.getAttribute('data-bs-id');
                            const response = await fetch(`/api/check-availability/?resourceId=${roomId}&arrivalDate=${arrivalDate}&departureDate=${departureDate}&isForOwner=true`);
                            const data = await response.json();
                            option.disabled = !data.available;
                            option.style.backgroundColor = data.available ? 'lightgreen' : 'lightcoral';
                        }
                    } catch (error) {
                        Swal.fire({ icon: 'error', title: 'Error', text: error.message, confirmButtonText: 'Aceptar' });
                    } finally {
                        ownerAvailability.style.display = 'none';
                        ownerRoomSelect.disabled = false;
                    }
                }
            });
        }

        if (ownerRoomSelect) {
            ownerRoomSelect.addEventListener('change', function () {
                const selectedOption = ownerRoomSelect.options[ownerRoomSelect.selectedIndex];
                ownerOccInput.value = selectedOption?.getAttribute('data-bs-pax') || '';
                ownerRoomIdInput.value = selectedOption?.getAttribute('data-bs-id') || '';
            });
        }

        const saveOwnerBtn = document.getElementById('save-owner-event-btn');
        if (saveOwnerBtn) {
            saveOwnerBtn.addEventListener('click', async function () {
                try {
                    const formData = {
                        arrivalDate: ownerStart.value.trim(),
                        departureDate: ownerEnd.value.trim(),
                        nNights: ownerNights.value.trim(),
                        chaletName: ownerRoomSelect.value.trim(),
                        maxOccupation: ownerOccInput.value.trim(),
                        clienteProvisional: document.getElementById('owner_cliente_name').value.trim(),
                    };

                    if (!formData.arrivalDate || !formData.departureDate || !formData.nNights || !formData.chaletName || !formData.clienteProvisional) {
                        throw new Error('Completa todos los campos obligatorios');
                    }

                    const response = await fetch('/api/eventos/reservadueno', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(formData)
                    });

                    if (!response.ok) {
                        const errorData = await response.json();
                        throw new Error(errorData.message || errorData?.error?.[0]?.message || 'Error al apartar fechas');
                    }

                    const data = await response.json();
                    Swal.fire({
                        icon: 'success',
                        title: 'Reserva creada',
                        text: data.message,
                        confirmButtonText: 'Aceptar'
                    }).then(() => window.location.reload());
                } catch (error) {
                    Swal.fire({
                        icon: 'error',
                        title: 'Error',
                        text: `Ha ocurrido un error al crear la reserva: ${error.message}`,
                        confirmButtonText: 'Aceptar'
                    });
                }
            });
        }
    });
</script>
