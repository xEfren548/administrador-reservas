<!-- Modal Carga Masiva por Reglas (Side Modal) -->
<div class="modal fade" id="bulk-rules-modal" tabindex="-1" role="dialog" aria-labelledby="bulkRulesModalLabel"
	aria-hidden="true">
	<div class="modal-dialog modal-dialog-scrollable ml-auto ms-auto m-0" role="document"
		style="max-width: 50vw; width: 50vw; height: 100vh;">
		<div class="modal-content h-100 border-0 rounded-0">
			<div class="modal-header">
				<h5 class="modal-title" id="bulkRulesModalLabel">Carga masiva por reglas</h5>
				<button type="button" class="close" data-bs-dismiss="modal" aria-label="Close">
					&times;
				</button>
			</div>
			<div class="modal-body" style="overflow-y: auto; overflow-x: hidden;">
				<div class="alert alert-info py-2 mb-3">
					<div><b>Prototipo visual:</b> esta version solo arma reglas y simula envio.</div>
					<div><b>noPersonas = 0</b> se enviara a General y <b>noPersonas = 1+</b> a Especial por personas.</div>
					<div>Flujo sugerido: <b>1) Define calendario A/R/E/SE</b> -> <b>2) Carga precios por temporada</b>.</div>
				</div>

				<div class="d-flex mb-3">
					<button type="button" class="btn btn-sm btn-primary mr-2" id="bulk-step-1-btn">Paso 1: Calendario</button>
					<button type="button" class="btn btn-sm btn-outline-primary" id="bulk-step-2-btn">Paso 2: Precios</button>
				</div>

				<div id="bulk-step-1-section">
					<div class="card mb-3">
						<div class="card-body">
							<div class="row">
								<div class="col-12 col-md-4 mb-2">
									<label class="form-label">Año de trabajo</label>
									<input type="number" min="2000" max="2100" class="form-control" id="bulk-calendar-year-input">
								</div>
								<div class="col-12 col-md-8 mb-2 d-flex align-items-end">
									<button type="button" class="btn btn-outline-secondary btn-sm mr-2" id="bulk-calendar-fill-regular">Rellenar todo R</button>
								</div>
							</div>

							<div class="border rounded p-2 bg-light mb-2">
								<div class="row">
									<div class="col-12 col-md-3 mb-2">
										<label class="form-label">Desde</label>
										<input type="date" class="form-control" id="bulk-calendar-range-start">
									</div>
									<div class="col-12 col-md-3 mb-2">
										<label class="form-label">Hasta</label>
										<input type="date" class="form-control" id="bulk-calendar-range-end">
									</div>
									<div class="col-12 col-md-3 mb-2">
										<label class="form-label">Temporada</label>
										<select class="form-select" id="bulk-calendar-range-season">
											<option value="R">R - Regular</option>
											<option value="A">A - Alta</option>
											<option value="E">E - Especial</option>
											<option value="SE">SE - Super especial</option>
										</select>
									</div>
									<div class="col-12 col-md-3 mb-2 d-flex align-items-end">
										<button type="button" class="btn btn-primary w-100" id="bulk-calendar-apply-range">Aplicar rango</button>
									</div>
								</div>
