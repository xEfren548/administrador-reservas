	function convertirFechaMexicoCity(fechaISO) {
		const fecha = new Date(fechaISO);
		const opciones = {
			timeZone: 'America/Mexico_City',
			year: 'numeric',
			month: '2-digit',
			day: '2-digit',
			hour: '2-digit',
			minute: '2-digit',
			second: '2-digit',
		};

		const formatter = new Intl.DateTimeFormat('es-MX', opciones);
		return formatter.format(fecha);
	}

