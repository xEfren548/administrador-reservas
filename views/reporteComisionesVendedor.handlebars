<div class="min-h-screen bg-[radial-gradient(circle_at_top,_rgba(14,116,144,0.12),_transparent_45%),linear-gradient(180deg,#f8fafc_0%,#eef6f9_100%)] py-8 px-2 sm:px-3 lg:px-4 2xl:px-5">
    <div class="w-full max-w-none space-y-6">
        <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
            <div>
                <p class="text-sm font-semibold uppercase tracking-[0.25em] text-cyan-700">Reportes</p>
                <h1 class="mt-2 text-3xl font-bold text-slate-900">Corte de Comisiones por Vendedor</h1>
                <p class="mt-2 max-w-3xl text-sm text-slate-600">
                    Consulta a los vendedores con comisión positiva por reserva, revisa su detalle individual y genera la solicitud correspondiente en finanzas.
                </p>
            </div>
        </div>

        <div class="rounded-3xl border border-slate-200 bg-white/95 p-6 shadow-xl shadow-slate-200/60">
            <div class="grid grid-cols-1 gap-4 md:grid-cols-[minmax(0,1fr)_auto_auto_auto] md:items-end">
                <div>
                    <label for="mesReporte" class="mb-2 block text-sm font-medium text-slate-700">Mes</label>
                    <input
                        type="month"
                        id="mesReporte"
                        name="mesReporte"
                        class="w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-slate-900 shadow-sm outline-none transition focus:border-cyan-500 focus:ring-2 focus:ring-cyan-200"
                        required
                    >
                </div>

                <button
                    id="btnConsultarReporte"
                    type="button"
                    onclick="consultarReporteComisiones()"
                    class="inline-flex items-center justify-center rounded-2xl bg-cyan-700 px-5 py-3 text-sm font-semibold text-white transition hover:bg-cyan-800 focus:outline-none focus:ring-2 focus:ring-cyan-300"
                >
                    Consultar vendedores
                </button>

                <button
                    id="btnDescargarReporteCompleto"
                    type="button"
                    onclick="descargarReportesMasivos()"
                    class="inline-flex items-center justify-center rounded-2xl bg-slate-900 px-5 py-3 text-sm font-semibold text-white transition hover:bg-slate-800 focus:outline-none focus:ring-2 focus:ring-slate-300"
                >
                    Descargar reportes masivos
                </button>

                <button
                    id="btnLimpiarFiltros"
                    type="button"
                    onclick="limpiarFiltrosComisiones()"
                    class="inline-flex items-center justify-center rounded-2xl border border-slate-300 px-5 py-3 text-sm font-semibold text-slate-700 transition hover:bg-slate-100 focus:outline-none focus:ring-2 focus:ring-slate-300"
                >
                    Limpiar
                </button>
            </div>

            <div id="mensajeEstado" class="mt-4 hidden rounded-2xl border px-4 py-3 text-sm"></div>

            <div id="loadingIndicator" class="mt-4 hidden rounded-2xl border border-cyan-200 bg-cyan-50 px-4 py-4 text-cyan-800">
                <div class="flex items-center gap-3">
                    <svg class="h-5 w-5 animate-spin" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
                    </svg>
                    <span>Consultando comisiones por vendedor...</span>
                </div>
            </div>
        </div>

        <div id="resumenCards" class="hidden grid grid-cols-1 gap-4 md:grid-cols-2 xl:grid-cols-4">
            <div class="rounded-3xl border border-slate-200 bg-white/95 p-5 shadow-lg shadow-slate-200/60">
                <p class="text-sm font-medium text-slate-500">Vendedores con comisión</p>
                <p id="resumenTotalVendedores" class="mt-3 text-3xl font-bold text-slate-900">0</p>
            </div>
            <div class="rounded-3xl border border-slate-200 bg-white/95 p-5 shadow-lg shadow-slate-200/60">
                <p class="text-sm font-medium text-slate-500">Monto acumulado</p>
                <p id="resumenTotalComisiones" class="mt-3 text-3xl font-bold text-slate-900">$0.00</p>
            </div>
            <div class="rounded-3xl border border-slate-200 bg-white/95 p-5 shadow-lg shadow-slate-200/60">
                <p class="text-sm font-medium text-slate-500">Cuentas listas</p>
                <p id="resumenCuentasListas" class="mt-3 text-3xl font-bold text-emerald-700">0</p>
            </div>
            <div class="rounded-3xl border border-slate-200 bg-white/95 p-5 shadow-lg shadow-slate-200/60">
                <p class="text-sm font-medium text-slate-500">Pendientes de cuenta</p>
                <p id="resumenCuentasPendientes" class="mt-3 text-3xl font-bold text-amber-600">0</p>
            </div>
        </div>

        <div class="rounded-3xl border border-slate-200 bg-white/95 p-6 shadow-xl shadow-slate-200/60">
            <div class="flex flex-col gap-3 border-b border-slate-200 pb-4 md:flex-row md:items-center md:justify-between">
                <div>
                    <h2 class="text-xl font-bold text-slate-900">Resultado por vendedor</h2>
                    <p class="mt-1 text-sm text-slate-500">
                        Las cuentas disponibles se infieren con base en las cuentas activas de finanzas donde el vendedor aparece como propietario.
                    </p>
                </div>
                <span id="resumenPeriodo" class="rounded-full bg-slate-100 px-4 py-2 text-sm font-medium text-slate-600">Sin consulta</span>
            </div>

            <div class="mt-5 overflow-hidden rounded-3xl border border-slate-200">
                <div class="overflow-x-auto">
                    <table class="min-w-full divide-y divide-slate-200 text-sm">
                        <thead class="bg-slate-50 text-left text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">
                            <tr>
                                <th class="px-4 py-4">Vendedor</th>
                                <th class="px-4 py-4">Comisión total</th>
                                <th class="px-4 py-4">Reservas</th>
                                <th class="px-4 py-4">Cuenta destino</th>
                                <th class="px-4 py-4">Estatus</th>
                                <th class="px-4 py-4 text-right">Acciones</th>
                            </tr>
                        </thead>
                        <tbody id="tablaVendedoresBody" class="divide-y divide-slate-200 bg-white">
                            <tr>
                                <td colspan="6" class="px-4 py-12 text-center text-slate-500">
                                    Selecciona el mes a consultar para generar el corte de comisiones.
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/xlsx-js-style@1.2.0/dist/xlsx.bundle.js"></script>
<script src="https://cdn.jsdelivr.net/npm/jszip@3.10.1/dist/jszip.min.js"></script>

<script>
const currencyFormatter = new Intl.NumberFormat('es-MX', {
    style: 'currency',
    currency: 'MXN'
});

let reporteActual = [];
const cuentasSeleccionadas = {};
const detallesAbiertos = new Set();

const monthFormatter = new Intl.DateTimeFormat('es-MX', {
    month: 'long',
    year: 'numeric',
    timeZone: 'UTC'
});

function formatMonthInputValue(date) {
    const year = date.getFullYear();
    const month = String(date.getMonth() + 1).padStart(2, '0');
    return `${year}-${month}`;
}

function parseMonthValue(monthValue) {
    if (!monthValue) {
        return null;
    }

    const [year, month] = monthValue.split('-').map(Number);
    if (!year || !month) {
        return null;
    }

    return { year, month };
}

function getMonthBoundary(monthValue, boundary) {
    const parsed = parseMonthValue(monthValue);
    if (!parsed) {
        return null;
    }

    const date = boundary === 'start'
        ? new Date(Date.UTC(parsed.year, parsed.month - 1, 1))
        : new Date(Date.UTC(parsed.year, parsed.month, 0));

    return date.toISOString().split('T')[0];
}

function buildMonthLabel(monthValue) {
    const parsed = parseMonthValue(monthValue);
    if (!parsed) {
        return '';
    }

    const label = monthFormatter.format(new Date(Date.UTC(parsed.year, parsed.month - 1, 1)));
    return label.charAt(0).toUpperCase() + label.slice(1);
}

function buildPeriodLabel(monthValue) {
    const monthLabel = buildMonthLabel(monthValue);

    if (!monthLabel) {
        return 'Sin consulta';
    }

    return monthLabel;
}

function setDefaultDates() {
    const now = new Date();
    const currentMonth = formatMonthInputValue(now);

    document.getElementById('mesReporte').value = currentMonth;
}

function escapeHtml(value) {
    return String(value ?? '')
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
}

function showMessage(message, type = 'info') {
    const messageBox = document.getElementById('mensajeEstado');
    const styles = {
        success: 'border-emerald-200 bg-emerald-50 text-emerald-800',
        error: 'border-rose-200 bg-rose-50 text-rose-800',
        warning: 'border-amber-200 bg-amber-50 text-amber-800',
        info: 'border-cyan-200 bg-cyan-50 text-cyan-800'
    };

    messageBox.className = `mt-4 rounded-2xl border px-4 py-3 text-sm ${styles[type] || styles.info}`;
    messageBox.textContent = message;
    messageBox.classList.remove('hidden');
}

function hideMessage() {
    document.getElementById('mensajeEstado').classList.add('hidden');
}

function toggleLoading(show) {
    document.getElementById('loadingIndicator').classList.toggle('hidden', !show);
    document.getElementById('btnConsultarReporte').disabled = show;
    document.getElementById('btnConsultarReporte').classList.toggle('opacity-60', show);
}

function getDateRangeOrNotify() {
    const mesReporte = document.getElementById('mesReporte').value;

    if (!mesReporte) {
        showMessage('Selecciona el mes a consultar.', 'warning');
        return null;
    }

    const fechaInicio = getMonthBoundary(mesReporte, 'start');
    const fechaFin = getMonthBoundary(mesReporte, 'end');

    if (!fechaInicio || !fechaFin) {
        showMessage('No fue posible interpretar el mes seleccionado.', 'error');
        return null;
    }

    return {
        fechaInicio,
        fechaFin,
        mesReporte,
        periodoTexto: buildPeriodLabel(mesReporte)
    };
}

function formatCurrency(amount) {
    return currencyFormatter.format(Number(amount) || 0);
}

function sanitizeFileName(value) {
    return String(value ?? 'reporte')
        .normalize('NFD')
        .replace(/[\u0300-\u036f]/g, '')
        .replace(/[^a-zA-Z0-9-_]+/g, '_')
        .replace(/_+/g, '_')
        .replace(/^_|_$/g, '') || 'reporte';
}

function downloadBlob(blob, fileName) {
    const url = URL.createObjectURL(blob);
    const anchor = document.createElement('a');
    anchor.href = url;
    anchor.download = fileName;
    document.body.appendChild(anchor);
    anchor.click();
    document.body.removeChild(anchor);
    URL.revokeObjectURL(url);
}

function workbookToBlob(workbook) {
    const workbookArray = XLSX.write(workbook, { bookType: 'xlsx', type: 'array' });
    return new Blob([
        workbookArray
    ], {
        type: 'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet'
    });
}

function updateSummary(totales, periodoTexto) {
    document.getElementById('resumenCards').classList.remove('hidden');
    document.getElementById('resumenTotalVendedores').textContent = totales.totalVendedores || 0;
    document.getElementById('resumenTotalComisiones').textContent = formatCurrency(totales.totalComisiones || 0);
    document.getElementById('resumenCuentasListas').textContent = totales.vendedoresConCuentaLista || 0;
    document.getElementById('resumenCuentasPendientes').textContent = totales.vendedoresSinCuenta || 0;
    document.getElementById('resumenPeriodo').textContent = periodoTexto || 'Sin consulta';
}

function buildAccountCell(vendedor) {
    if (!vendedor.cuentasDestino || vendedor.cuentasDestino.length === 0) {
        return '<span class="inline-flex rounded-full bg-amber-100 px-3 py-1 text-xs font-semibold text-amber-700">Sin cuenta ligada</span>';
    }

    if (vendedor.cuentasDestino.length === 1) {
        const cuenta = vendedor.cuentasDestino[0];
        cuentasSeleccionadas[vendedor.vendedorId] = cuenta._id;
        return `
            <div>
                <p class="font-semibold text-slate-900">${escapeHtml(cuenta.nombre)}</p>
                <p class="text-xs text-slate-500">${escapeHtml(cuenta.organizacion)} · ${escapeHtml(cuenta.moneda)}</p>
            </div>
        `;
    }

    const selectedValue = cuentasSeleccionadas[vendedor.vendedorId] || '';
    const options = vendedor.cuentasDestino.map((cuenta) => `
        <option value="${escapeHtml(cuenta._id)}" ${cuenta._id === selectedValue ? 'selected' : ''}>
            ${escapeHtml(cuenta.nombre)} · ${escapeHtml(cuenta.organizacion)}
        </option>
    `).join('');

    return `
        <select
            class="w-full rounded-xl border border-slate-200 bg-slate-50 px-3 py-2 text-sm text-slate-700 outline-none transition focus:border-cyan-500 focus:ring-2 focus:ring-cyan-200"
            onchange="seleccionarCuenta('${escapeHtml(vendedor.vendedorId)}', this.value)"
        >
            <option value="">Selecciona una cuenta</option>
            ${options}
        </select>
    `;
}

function buildStatusBadge(vendedor) {
    if (vendedor.solicitudCreada) {
        return '<span class="inline-flex rounded-full bg-emerald-100 px-3 py-1 text-xs font-semibold text-emerald-700">Solicitud creada</span>';
    }

    if (vendedor.estadoCuenta === 'lista') {
        return '<span class="inline-flex rounded-full bg-emerald-100 px-3 py-1 text-xs font-semibold text-emerald-700">Lista para enviar</span>';
    }

    if (vendedor.estadoCuenta === 'seleccion-requerida') {
        return '<span class="inline-flex rounded-full bg-sky-100 px-3 py-1 text-xs font-semibold text-sky-700">Selecciona una cuenta</span>';
    }

    return '<span class="inline-flex rounded-full bg-amber-100 px-3 py-1 text-xs font-semibold text-amber-700">Configurar cuenta</span>';
}

function buildReservationDetail(vendedor) {
    return vendedor.reservas.map((reserva) => {
        const detalles = reserva.detalles.map((detalle) => `
            <li class="flex items-center justify-between gap-3 rounded-xl bg-slate-50 px-3 py-2 text-xs text-slate-600">
                <span>${escapeHtml(detalle.concepto)}</span>
                <span class="font-semibold text-slate-900">${formatCurrency(detalle.monto)}</span>
            </li>
        `).join('');

        return `
            <div class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
                <div class="flex flex-col gap-3 md:flex-row md:items-start md:justify-between">
                    <div>
                        <p class="text-sm font-semibold text-slate-900">${escapeHtml(reserva.cabana)}</p>
                        <p class="mt-1 text-xs text-slate-500">Reserva ${escapeHtml(reserva.idReserva)}</p>
                        <p class="mt-2 text-xs text-slate-500">${escapeHtml(reserva.fechaEntrada)} al ${escapeHtml(reserva.fechaSalida)} · ${escapeHtml(reserva.noches)} noches</p>
                    </div>
                    <div class="rounded-2xl bg-cyan-50 px-4 py-3 text-right">
                        <p class="text-xs uppercase tracking-[0.2em] text-cyan-700">Total reserva</p>
                        <p class="mt-1 text-lg font-bold text-cyan-900">${formatCurrency(reserva.totalComision)}</p>
                    </div>
                </div>
                <ul class="mt-4 space-y-2">${detalles}</ul>
            </div>
        `;
    }).join('');
}

function renderTable() {
    const tableBody = document.getElementById('tablaVendedoresBody');

    if (!reporteActual.length) {
        tableBody.innerHTML = `
            <tr>
                <td colspan="6" class="px-4 py-12 text-center text-slate-500">
                    No se encontraron vendedores con comisión positiva en el mes seleccionado.
                </td>
            </tr>
        `;
        return;
    }

    tableBody.innerHTML = reporteActual.map((vendedor) => {
        const cuentaId = cuentasSeleccionadas[vendedor.vendedorId] || vendedor.cuentaDestinoSugerida?._id || '';
        const canCreateRequest = Boolean(cuentaId) && !vendedor.solicitudCreada;
        const detalleOpen = detallesAbiertos.has(vendedor.vendedorId);

        return `
            <tr class="align-top">
                <td class="px-4 py-4">
                    <p class="font-semibold text-slate-900">${escapeHtml(vendedor.vendedorNombre)}</p>
                    <p class="mt-1 text-xs text-slate-500">${escapeHtml(vendedor.vendedorId)}</p>
                </td>
                <td class="px-4 py-4 font-semibold text-slate-900">${formatCurrency(vendedor.totalComisiones)}</td>
                <td class="px-4 py-4 text-slate-600">${vendedor.totalReservas}</td>
                <td class="px-4 py-4">${buildAccountCell(vendedor)}</td>
                <td class="px-4 py-4">${buildStatusBadge(vendedor)}</td>
                <td class="px-4 py-4">
                    <div class="flex flex-col items-end gap-2">
                        <button
                            type="button"
                            onclick="toggleDetalle('${escapeHtml(vendedor.vendedorId)}')"
                            class="inline-flex items-center justify-center rounded-xl border border-slate-300 px-3 py-2 text-xs font-semibold text-slate-700 transition hover:bg-slate-100"
                        >
                            ${detalleOpen ? 'Ocultar detalle' : 'Ver detalle'}
                        </button>
                        <button
                            type="button"
                            onclick="descargarReporteVendedor('${escapeHtml(vendedor.vendedorId)}')"
                            class="inline-flex items-center justify-center rounded-xl bg-slate-900 px-3 py-2 text-xs font-semibold text-white transition hover:bg-slate-800"
                        >
                            Descargar reporte
                        </button>
                        <button
                            type="button"
                            onclick="crearSolicitudFinanzas('${escapeHtml(vendedor.vendedorId)}')"
                            class="inline-flex items-center justify-center rounded-xl bg-emerald-600 px-3 py-2 text-xs font-semibold text-white transition hover:bg-emerald-700 disabled:cursor-not-allowed disabled:bg-slate-300"
                            ${canCreateRequest ? '' : 'disabled'}
                        >
                            ${vendedor.solicitudCreada ? 'Solicitud creada' : 'Crear solicitud en finanzas'}
                        </button>
                    </div>
                </td>
            </tr>
            <tr class="${detalleOpen ? '' : 'hidden'}" id="detalle-${escapeHtml(vendedor.vendedorId)}">
                <td colspan="6" class="bg-slate-50 px-4 py-5">
                    <div class="space-y-3">
                        ${buildReservationDetail(vendedor)}
                    </div>
                </td>
            </tr>
        `;
    }).join('');
}

function seleccionarCuenta(vendedorId, cuentaId) {
    cuentasSeleccionadas[vendedorId] = cuentaId;
    renderTable();
}

function toggleDetalle(vendedorId) {
    if (detallesAbiertos.has(vendedorId)) {
        detallesAbiertos.delete(vendedorId);
    } else {
        detallesAbiertos.add(vendedorId);
    }

    renderTable();
}

async function consultarReporteComisiones() {
    hideMessage();
    const dateRange = getDateRangeOrNotify();

    if (!dateRange) {
        return;
    }

    const { fechaInicio, fechaFin, periodoTexto } = dateRange;

    toggleLoading(true);

    try {
        const response = await fetch(`/api/reportes/comisiones-vendedor?fechaInicio=${fechaInicio}&fechaFin=${fechaFin}`);
        const payload = await response.json();

        if (!response.ok || !payload.success) {
            throw new Error(payload.message || payload.error || 'No fue posible consultar el reporte.');
        }

        reporteActual = payload.data || [];
        Object.keys(cuentasSeleccionadas).forEach((key) => delete cuentasSeleccionadas[key]);
        detallesAbiertos.clear();

        reporteActual.forEach((vendedor) => {
            if (vendedor.cuentaDestinoSugerida?._id) {
                cuentasSeleccionadas[vendedor.vendedorId] = vendedor.cuentaDestinoSugerida._id;
            }
        });

        updateSummary(payload.totales || {}, periodoTexto);
        renderTable();

        if (!reporteActual.length) {
            showMessage('No se encontraron vendedores con comisión positiva en el mes consultado.', 'info');
        } else {
            showMessage(`Consulta completada. Se encontraron ${reporteActual.length} vendedores con comisiones.`, 'success');
        }
    } catch (error) {
        reporteActual = [];
        renderTable();
        showMessage(error.message, 'error');
    } finally {
        toggleLoading(false);
    }
}

async function descargarReporteVendedor(vendedorId) {
    hideMessage();
    const dateRange = getDateRangeOrNotify();
    if (!dateRange) {
        return;
    }

    const { fechaInicio, fechaFin } = dateRange;
    const vendedor = reporteActual.find((item) => item.vendedorId === vendedorId);

    if (!vendedor) {
        showMessage('No se encontró el vendedor seleccionado en la consulta actual.', 'error');
        return;
    }

    try {
        const response = await fetch(`/api/reportes/datos?fechaInicio=${fechaInicio}&fechaFin=${fechaFin}&sellerId=${encodeURIComponent(vendedorId)}`);

        if (!response.ok) {
            throw new Error(`Error en la respuesta del servidor: ${response.status}`);
        }

        const data = await response.json();

        if (!data.success) {
            throw new Error(data.error || 'Error al obtener el reporte individual del vendedor');
        }

        if (!data.data || data.data.length === 0) {
            showMessage(`No se encontraron reservas para ${vendedor.vendedorNombre} en el mes seleccionado.`, 'warning');
            return;
        }

        const workbook = buildWorkbookReporteCompleto(data, fechaInicio, fechaFin);
        const blob = workbookToBlob(workbook);
        const sellerLabel = sanitizeFileName(vendedor.vendedorNombre);
        downloadBlob(blob, `Reporte_TodoEnUno_${sellerLabel}_${fechaInicio}_${fechaFin}.xlsx`);
        showMessage(`Reporte descargado para ${vendedor.vendedorNombre}.`, 'success');
    } catch (error) {
        console.error('Error al descargar el reporte individual:', error);
        showMessage(`Error al descargar el reporte individual: ${error.message}`, 'error');
    }
}

async function descargarReportesMasivos() {
    hideMessage();
    const dateRange = getDateRangeOrNotify();
    if (!dateRange) {
        return;
    }

    if (!reporteActual.length) {
        showMessage('Primero consulta los vendedores para generar la descarga masiva.', 'warning');
        return;
    }

    const { fechaInicio, fechaFin } = dateRange;
    const downloadButton = document.getElementById('btnDescargarReporteCompleto');

    downloadButton.disabled = true;
    downloadButton.classList.add('opacity-60', 'cursor-not-allowed');

    try {
        const zip = new JSZip();
        let reportesAgregados = 0;

        for (const vendedor of reporteActual) {
            const response = await fetch(`/api/reportes/datos?fechaInicio=${fechaInicio}&fechaFin=${fechaFin}&sellerId=${encodeURIComponent(vendedor.vendedorId)}`);

            if (!response.ok) {
                throw new Error(`Error en la descarga de ${vendedor.vendedorNombre}: ${response.status}`);
            }

            const data = await response.json();
            if (!data.success || !data.data || data.data.length === 0) {
                continue;
            }

            const workbook = buildWorkbookReporteCompleto(data, fechaInicio, fechaFin);
            const blob = workbookToBlob(workbook);
            const sellerLabel = sanitizeFileName(vendedor.vendedorNombre);
            zip.file(`Reporte_TodoEnUno_${sellerLabel}_${fechaInicio}_${fechaFin}.xlsx`, blob);
            reportesAgregados += 1;
        }

        if (!reportesAgregados) {
            showMessage('No se encontraron reportes individuales para incluir en la descarga masiva.', 'warning');
            return;
        }

        const zipBlob = await zip.generateAsync({ type: 'blob' });
        downloadBlob(zipBlob, `Reportes_Comisiones_Vendedores_${fechaInicio}_${fechaFin}.zip`);
        showMessage(`Descarga masiva completada. Se incluyeron ${reportesAgregados} reportes individuales.`, 'success');
    } catch (error) {
        console.error('Error al descargar los reportes masivos:', error);
        showMessage(`Error al descargar los reportes masivos: ${error.message}`, 'error');
    } finally {
        downloadButton.disabled = false;
        downloadButton.classList.remove('opacity-60', 'cursor-not-allowed');
    }
}

function buildWorkbookReporteCompleto(data, fechaInicio, fechaFin) {
    const workbook = XLSX.utils.book_new();

    const categorias = [
        { nombre: 'Identificación', columnas: ['ID Reserva', 'Estatus'], color: 'E7E6E6', colorDatos: 'F2F2F2' },
        { nombre: 'Administración', columnas: ['Admin Cabaña', 'Agente Reserva'], color: 'E7E6E6', colorDatos: 'F2F2F2' },
        { nombre: 'Información de Reserva', columnas: ['Cabaña', 'Agencia', 'Fecha Entrada', 'Fecha Salida', 'Noches', 'Huéspedes'], color: 'FFD966', colorDatos: 'FFF2CC' },
        { nombre: 'Ingresos Base', columnas: ['Precio Base/Noche', 'Ganancia inversionista/Dueño', 'Pago a Dueño', 'Utilidad', 'Limpieza', 'Administrador ligado'], color: '87CEEB', colorDatos: 'D9EDF7' },
        { nombre: 'Comisiones', columnas: ['Admin NyN', 'Comisión Agencia', 'Comisión Gerente', 'Comisión Admin', 'Comisión Vendedor'], color: 'FFA500', colorDatos: 'FFE5CC' },
        { nombre: 'Pagos Cliente', columnas: ['Precio Reserva', 'Total Pagado', 'Pagos Transferencia', 'Pagos Recibió Dueño', 'Pagos Restante', 'Excedente', 'Inversionistas'], color: 'C0C0C0', colorDatos: 'E8E8E8' },
        { nombre: 'Cliente', columnas: ['Cliente', 'Correo', 'Teléfono'], color: 'FFD966', colorDatos: 'FFF2CC' },
        { nombre: 'Observaciones', columnas: ['Notas', 'Notas Privadas'], color: 'E7E6E6', colorDatos: 'F2F2F2' }
    ];

    const worksheetData = [];
    const categoriaRow = [];
    const merges = [];
    let colIndex = 0;

    categorias.forEach((categoria) => {
        const inicio = colIndex;
        const fin = colIndex + categoria.columnas.length - 1;

        categoriaRow.push(categoria.nombre);

        for (let i = 1; i < categoria.columnas.length; i += 1) {
            categoriaRow.push('');
        }

        merges.push({
            s: { r: 0, c: inicio },
            e: { r: 0, c: fin },
            color: categoria.color,
            colorDatos: categoria.colorDatos
        });

        colIndex += categoria.columnas.length;
    });

    const coloresColumnas = [];
    categorias.forEach((categoria) => {
        for (let i = 0; i < categoria.columnas.length; i += 1) {
            coloresColumnas.push(categoria.colorDatos);
        }
    });

    worksheetData.push(categoriaRow);
    worksheetData.push(data.headers.map((header) => header.label));

    data.data.forEach((registro) => {
        const row = data.headers.map((header) => {
            const valor = registro[header.key];

            if (valor === null || valor === undefined) {
                return '';
            }

            if (header.key.includes('fecha') || header.key.includes('Fecha')) {
                return valor;
            }

            if (typeof valor === 'number') {
                return valor;
            }

            return valor;
        });

        worksheetData.push(row);
    });

    const totalesRow = [];
    data.headers.forEach((header, index) => {
        if (index === 0) {
            totalesRow.push('TOTALES');
        } else if (header.key === 'noches') {
            totalesRow.push(data.totales.totalNoches || 0);
        } else if (header.key === 'agencia') {
            totalesRow.push(data.totales.totalAgencia || 0);
        } else if (header.key === 'precioReserva') {
            totalesRow.push(data.totales.totalPrecioReservas || 0);
        } else if (header.key === 'administracionNyN') {
            totalesRow.push(data.totales.totalComisionSistema || 0);
        } else if (header.key === 'comisionAgencia') {
            totalesRow.push(data.totales.totalComisionAgencia || 0);
        } else if (header.key === 'comisionAdminCabana') {
            totalesRow.push(data.totales.totalComisionAdmin || 0);
        } else if (header.key === 'comisionVendedor') {
            totalesRow.push(data.totales.totalComisionVendedor || 0);
        } else if (header.key === 'pagoADueno') {
            totalesRow.push(data.totales.totalPagoADueno || 0);
        } else if (header.key === 'utilidadTotal') {
            totalesRow.push(data.totales.totalUtilidades || 0);
        } else if (header.key === 'totalPagado') {
            totalesRow.push(data.totales.totalIngresos || 0);
        } else if (header.key === 'pagosTransferencia') {
            totalesRow.push(data.totales.totalPagosTransferencia || 0);
        } else if (header.key === 'pagosRecibioDueno') {
            totalesRow.push(data.totales.totalPagosRecibioDueno || 0);
        } else if (header.key === 'pagosRestante') {
            totalesRow.push(data.totales.totalPagosRestante || 0);
        } else if (header.key === 'excedente') {
            totalesRow.push(data.totales.totalExcedente || 0);
        } else {
            totalesRow.push('');
        }
    });

    worksheetData.push(totalesRow);

    const worksheet = XLSX.utils.aoa_to_sheet(worksheetData);
    worksheet['!cols'] = data.headers.map((header) => ({ wch: header.width || 15 }));

    const range = XLSX.utils.decode_range(worksheet['!ref']);
    const columnasMonetarias = [
        'precioBasePorNoche', 'precioBase', 'pagoADueno', 'precioReserva', 'limpieza',
        'participacionBosques', 'administracionNyN', 'comisionAgencia', 'comisionAdminCabana',
        'comisionGerente', 'comisionVendedor', 'utilidadTotal',
        'comisionInversionistas', 'comisionDueno', 'totalPagado',
        'pagosTransferencia', 'pagosRecibioDueno', 'pagosRestante',
        'pagosNoEfectivo', 'liquidaEfectivo', 'excedente', 'balanceDue', 'agencia'
    ];

    const indicesMonetarios = data.headers
        .map((header, idx) => (columnasMonetarias.includes(header.key) ? idx : -1))
        .filter((idx) => idx !== -1);

    for (let row = range.s.r; row <= range.e.r; row += 1) {
        for (let col = range.s.c; col <= range.e.c; col += 1) {
            const cellAddress = XLSX.utils.encode_cell({ r: row, c: col });

            if (!worksheet[cellAddress]) {
                worksheet[cellAddress] = { t: 's', v: '' };
            }

            if (row === 0) {
                const merge = merges.find((item) => col >= item.s.c && col <= item.e.c);
                const colorCategoria = merge ? merge.color : 'E7E6E6';

                worksheet[cellAddress].s = {
                    font: { bold: true, sz: 11, color: { rgb: '000000' } },
                    fill: { fgColor: { rgb: colorCategoria } },
                    alignment: { horizontal: 'center', vertical: 'center' },
                    border: {
                        top: { style: 'medium', color: { rgb: '000000' } },
                        bottom: { style: 'medium', color: { rgb: '000000' } },
                        left: { style: 'medium', color: { rgb: '000000' } },
                        right: { style: 'medium', color: { rgb: '000000' } }
                    }
                };
            } else if (row === 1) {
                worksheet[cellAddress].s = {
                    font: { bold: true, color: { rgb: 'FFFFFF' } },
                    fill: { fgColor: { rgb: '4B5563' } },
                    alignment: { horizontal: 'center', vertical: 'center' },
                    border: {
                        top: { style: 'thin', color: { rgb: '000000' } },
                        bottom: { style: 'thin', color: { rgb: '000000' } },
                        left: { style: 'thin', color: { rgb: '000000' } },
                        right: { style: 'thin', color: { rgb: '000000' } }
                    }
                };
            } else if (row === range.e.r) {
                worksheet[cellAddress].s = {
                    font: { bold: true },
                    fill: { fgColor: { rgb: 'FEF3C7' } },
                    alignment: {
                        horizontal: indicesMonetarios.includes(col) ? 'right' : 'left',
                        vertical: 'center'
                    },
                    border: {
                        top: { style: 'thin', color: { rgb: '000000' } },
                        bottom: { style: 'thin', color: { rgb: '000000' } },
                        left: { style: 'thin', color: { rgb: '000000' } },
                        right: { style: 'thin', color: { rgb: '000000' } }
                    }
                };

                if (indicesMonetarios.includes(col) && typeof worksheet[cellAddress].v === 'number') {
                    worksheet[cellAddress].z = '$#,##0.00';
                }
            } else {
                const colorColumna = coloresColumnas[col] || 'FFFFFF';

                worksheet[cellAddress].s = {
                    fill: { fgColor: { rgb: colorColumna } },
                    alignment: {
                        horizontal: indicesMonetarios.includes(col) ? 'right' : 'left',
                        vertical: 'center'
                    },
                    border: {
                        top: { style: 'thin', color: { rgb: 'E5E7EB' } },
                        bottom: { style: 'thin', color: { rgb: 'E5E7EB' } },
                        left: { style: 'thin', color: { rgb: 'E5E7EB' } },
                        right: { style: 'thin', color: { rgb: 'E5E7EB' } }
                    }
                };

                if (indicesMonetarios.includes(col) && typeof worksheet[cellAddress].v === 'number') {
                    worksheet[cellAddress].z = '$#,##0.00';
                }
            }
        }
    }

    worksheet['!merges'] = merges.map((merge) => ({
        s: { r: merge.s.r, c: merge.s.c },
        e: { r: merge.e.r, c: merge.e.c }
    }));

    XLSX.utils.book_append_sheet(workbook, worksheet, 'Reporte');

    const metadataData = [
        ['INFORMACIÓN DEL REPORTE'],
        [],
        ['Rango de fechas:', `${fechaInicio} - ${fechaFin}`],
        ['Fecha de generación:', data.metadata.fechaGeneracion],
        ['Total de registros:', data.metadata.totalRegistros],
        [],
        ['TOTALES GENERALES'],
        [],
        ['Total Reservas:', data.totales.totalReservas],
        ['Total Noches:', data.totales.totalNoches],
        ['Total Ingresos:', data.totales.totalIngresos],
        ['Total Precio Reservas:', data.totales.totalPrecioReservas],
        ['Total Comisión Sistema:', data.totales.totalComisionSistema],
        ['Total Comisión Admin:', data.totales.totalComisionAdmin],
        ['Total Comisión Vendedor:', data.totales.totalComisionVendedor],
        ['Total Utilidades:', data.totales.totalUtilidades],
        ['Total Excedente:', data.totales.totalExcedente]
    ];

    const metadataSheet = XLSX.utils.aoa_to_sheet(metadataData);
    metadataSheet['!cols'] = [{ wch: 30 }, { wch: 30 }];

    if (metadataSheet.A1) {
        metadataSheet.A1.s = {
            font: { bold: true, sz: 14 },
            fill: { fgColor: { rgb: '4B5563' } },
            alignment: { horizontal: 'center' }
        };
    }

    if (metadataSheet.A7) {
        metadataSheet.A7.s = {
            font: { bold: true, sz: 12 },
            fill: { fgColor: { rgb: '9CA3AF' } }
        };
    }

    ['B11', 'B12', 'B13', 'B14', 'B15', 'B16', 'B17', 'B18'].forEach((cell) => {
        if (metadataSheet[cell] && typeof metadataSheet[cell].v === 'number') {
            metadataSheet[cell].z = '$#,##0.00';
        }
    });

    XLSX.utils.book_append_sheet(workbook, metadataSheet, 'Metadata');
    return workbook;
}

async function crearSolicitudFinanzas(vendedorId) {
    const vendedor = reporteActual.find((item) => item.vendedorId === vendedorId);
    const dateRange = getDateRangeOrNotify();
    const cuentaId = cuentasSeleccionadas[vendedorId] || vendedor?.cuentaDestinoSugerida?._id;

    if (!dateRange) {
        return;
    }

    const { fechaInicio, fechaFin } = dateRange;

    if (!vendedor) {
        showMessage('No se encontró el vendedor seleccionado en la consulta actual.', 'error');
        return;
    }

    if (!cuentaId) {
        showMessage(`Selecciona una cuenta destino para ${vendedor.vendedorNombre}.`, 'warning');
        return;
    }

    try {
        hideMessage();

        const response = await fetch('/api/reportes/comisiones-vendedor/solicitudes', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify({
                fechaInicio,
                fechaFin,
                vendedorId,
                cuentaId
            })
        });

        const payload = await response.json();

        if (!response.ok || !payload.success) {
            throw new Error(payload.message || payload.error || 'No fue posible crear la solicitud.');
        }

        vendedor.solicitudCreada = true;
        renderTable();
        showMessage(`Solicitud creada en finanzas para ${vendedor.vendedorNombre}.`, 'success');
    } catch (error) {
        showMessage(error.message, 'error');
    }
}

function limpiarFiltrosComisiones() {
    setDefaultDates();
    reporteActual = [];
    detallesAbiertos.clear();
    Object.keys(cuentasSeleccionadas).forEach((key) => delete cuentasSeleccionadas[key]);
    document.getElementById('resumenCards').classList.add('hidden');
    document.getElementById('resumenPeriodo').textContent = 'Sin consulta';
    renderTable();
    hideMessage();
}

document.addEventListener('DOMContentLoaded', () => {
    setDefaultDates();
    renderTable();
});
</script>