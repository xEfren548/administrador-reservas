                            <p class="mt-1 text-lg font-bold ${reserva.esPagable ? 'text-emerald-900' : 'text-amber-900'}">${formatCurrency(reserva.totalComisionPagable)}</p>
                        </div>
                    </div>
                </div>
                <ul class="mt-4 space-y-2">${detalles}</ul>
            </div>
        `;
    }).join('');
}

