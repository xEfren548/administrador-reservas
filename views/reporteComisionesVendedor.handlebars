        detailPayableLabel: 'Pago pagable',
        reportFileName: (name, fechaInicio, fechaFin) => `Reporte_TodoEnUno_Dueno_${sanitizeFileName(name)}_${fechaInicio}_${fechaFin}.xlsx`,
