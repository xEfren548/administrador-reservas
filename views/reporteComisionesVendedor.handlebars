        requestNoPayable: (name) => `${name} no tiene pagos pagables para el periodo seleccionado.`,
        requestSuccess: (name) => `Solicitud creada en finanzas para ${name}.`,
        payableHint: (payableReservations, totalReservations) => `${payableReservations || 0} de ${totalReservations} reservas suman al pago`,
