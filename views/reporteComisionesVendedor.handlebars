        tableBody.innerHTML = `
            <tr>
                <td colspan="7" class="px-4 py-12 text-center text-slate-500">
                    ${escapeHtml(document.getElementById('resumenCards').classList.contains('hidden') ? content.initialEmptyText : content.emptyResultsText)}
