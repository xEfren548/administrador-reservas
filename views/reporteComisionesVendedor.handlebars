        bulkDownloadWarning: 'Primero consulta los dueños para generar la descarga masiva.',
        bulkDownloadEmpty: 'No se encontraron reportes individuales de dueños para incluir en la descarga masiva.',
        bulkDownloadSuccess: (count) => `Descarga masiva completada. Se incluyeron ${count} reportes individuales.`,
