function updateLinkedAccountsModalCopy() {
    const singularLabel = getActiveBeneficiaryLabel();
    const pluralLabel = getActiveBeneficiaryPluralLabel();
    document.getElementById('linkedAccountsModalTitle').textContent = `Cuentas ligadas de ${pluralLabel}`;
    document.getElementById('linkedAccountsModalDescription').textContent = `Administra la cuenta por defecto que se sugerirá para cada ${singularLabel} en el corte actual.`;
    document.getElementById('linkedAccountsColumnBeneficiary').textContent = singularLabel.charAt(0).toUpperCase() + singularLabel.slice(1);
    document.getElementById('linkedAccountsModalHint').textContent = activeBeneficiaryType === 'owner'
        ? 'Para dueños se muestran cuentas activas asociadas al propio dueño o ligadas a sus cabañas.'
        : 'Sólo se muestran cuentas activas de finanzas donde el vendedor aparece como propietario.';
}

function showLinkedAccountsMessage(message, type = 'info') {
    const messageBox = document.getElementById('linkedAccountsMessage');
    const styles = {
        success: 'border-emerald-200 bg-emerald-50 text-emerald-800',
        error: 'border-rose-200 bg-rose-50 text-rose-800',
        warning: 'border-amber-200 bg-amber-50 text-amber-800',
        info: 'border-cyan-200 bg-cyan-50 text-cyan-800'
    };

    messageBox.className = `mt-3 rounded-2xl border px-4 py-3 text-sm ${styles[type] || styles.info}`;
    messageBox.textContent = message;
    messageBox.classList.remove('hidden');
}

function hideLinkedAccountsMessage() {
    document.getElementById('linkedAccountsMessage').classList.add('hidden');
}

function setLinkedAccountsLoadingState(isLoading) {
    const button = document.getElementById('btnCuentasLigadas');
    button.disabled = isLoading;
    button.classList.toggle('opacity-60', isLoading);
}

function buildLinkedAccountStatusBadge(beneficiario) {
    if (beneficiario.cuentaLigada) {
        return '<span class="inline-flex rounded-full bg-emerald-100 px-3 py-1 text-xs font-semibold text-emerald-700">Cuenta ligada</span>';
    }

    if (beneficiario.estadoCuenta === 'seleccion-requerida') {
        return '<span class="inline-flex rounded-full bg-sky-100 px-3 py-1 text-xs font-semibold text-sky-700">Selecciona una cuenta</span>';
    }

    return '<span class="inline-flex rounded-full bg-amber-100 px-3 py-1 text-xs font-semibold text-amber-700">Sin cuenta ligada</span>';
}

function renderLinkedAccountsTable() {
    const tableBody = document.getElementById('linkedAccountsTableBody');
    const pluralLabel = getActiveBeneficiaryPluralLabel();

    if (!cuentasLigadasActuales.length) {
        tableBody.innerHTML = `
            <tr>
                <td colspan="5" class="px-4 py-12 text-center text-slate-500">
                    No se encontraron ${escapeHtml(pluralLabel)} para configurar en este módulo.
                </td>
            </tr>
        `;
        return;
    }

    tableBody.innerHTML = cuentasLigadasActuales.map((beneficiario) => {
        const selectedValue = Object.prototype.hasOwnProperty.call(cuentasLigadasSeleccionadas, beneficiario.beneficiarioId)
            ? cuentasLigadasSeleccionadas[beneficiario.beneficiarioId]
            : (beneficiario.cuentaLigada?._id || '');
        const cuentaActual = beneficiario.cuentaLigada
            ? `
                <div>
                    <p class="font-semibold text-slate-900">${escapeHtml(beneficiario.cuentaLigada.nombre)}</p>
                    <p class="text-xs text-slate-500">${escapeHtml(beneficiario.cuentaLigada.organizacion)} · ${escapeHtml(beneficiario.cuentaLigada.moneda)}</p>
                </div>
            `
            : '<span class="text-slate-400">Sin cuenta ligada</span>';
        const options = beneficiario.cuentasDestino.map((cuenta) => `
            <option value="${escapeHtml(cuenta._id)}" ${cuenta._id === selectedValue ? 'selected' : ''}>
                ${escapeHtml(cuenta.nombre)} · ${escapeHtml(cuenta.organizacion)}
            </option>
        `).join('');
        const isSaving = cuentasLigadasGuardando.has(beneficiario.beneficiarioId);
        const hasChanges = selectedValue !== (beneficiario.cuentaLigada?._id || '');

        return `
            <tr class="align-top">
                <td class="px-4 py-4">
                    <p class="font-semibold text-slate-900">${escapeHtml(beneficiario.beneficiarioNombre)}</p>
                    <p class="mt-1 text-xs text-slate-500">${escapeHtml(beneficiario.beneficiarioId)}</p>
                </td>
                <td class="px-4 py-4">${cuentaActual}</td>
                <td class="px-4 py-4">
                    <select
                        class="w-full min-w-[280px] rounded-xl border border-slate-200 bg-slate-50 px-3 py-2 text-sm text-slate-700 outline-none transition focus:border-cyan-500 focus:ring-2 focus:ring-cyan-200 disabled:cursor-not-allowed disabled:bg-slate-100"
                        onchange="seleccionarCuentaLigada('${escapeHtml(beneficiario.beneficiarioId)}', this.value)"
                        ${isSaving ? 'disabled' : ''}
                    >
                        <option value="">Sin cuenta ligada</option>
                        ${options}
                    </select>
                </td>
                <td class="px-4 py-4">${buildLinkedAccountStatusBadge(beneficiario)}</td>
                <td class="px-4 py-4">
                    <div class="flex justify-end">
                        <button
                            type="button"
                            onclick="guardarCuentaLigada('${escapeHtml(beneficiario.beneficiarioId)}')"
                            class="inline-flex items-center justify-center rounded-xl bg-cyan-700 px-4 py-2 text-xs font-semibold text-white transition hover:bg-cyan-800 disabled:cursor-not-allowed disabled:bg-slate-300"
                            ${isSaving || !hasChanges ? 'disabled' : ''}
                        >
                            ${isSaving ? 'Guardando...' : 'Guardar'}
                        </button>
                    </div>
                </td>
            </tr>
        `;
    }).join('');
}

async function openLinkedAccountsModal() {
    updateLinkedAccountsModalCopy();
    document.getElementById('linkedAccountsModal').classList.remove('hidden');
    document.body.classList.add('overflow-hidden');
    await cargarCuentasLigadas();
}

function closeLinkedAccountsModal() {
    document.getElementById('linkedAccountsModal').classList.add('hidden');
    document.body.classList.remove('overflow-hidden');
    hideLinkedAccountsMessage();
}

function seleccionarCuentaLigada(beneficiarioId, cuentaId) {
    cuentasLigadasSeleccionadas[beneficiarioId] = cuentaId;
    renderLinkedAccountsTable();
}

function syncLinkedAccountWithCurrentReport(data) {
    const beneficiario = reporteActual.find((item) => item.vendedorId === data.beneficiarioId);
    if (!beneficiario) {
        return;
    }

    beneficiario.cuentasDestino = data.cuentasDestino || [];
    beneficiario.cuentaLigada = data.cuentaLigada || null;
    beneficiario.cuentaDestinoSugerida = data.cuentaDestinoSugerida || null;
    beneficiario.estadoCuenta = data.estadoCuenta || 'sin-cuenta';

    if (data.cuentaDestinoSugerida?._id) {
        cuentasSeleccionadas[beneficiario.vendedorId] = data.cuentaDestinoSugerida._id;
    } else {
        delete cuentasSeleccionadas[beneficiario.vendedorId];
    }

    renderTable();
    refreshReportSummaryFromCurrentState();
}

async function cargarCuentasLigadas() {
    hideLinkedAccountsMessage();
    setLinkedAccountsLoadingState(true);
    document.getElementById('linkedAccountsModalCount').textContent = 'Cargando configuración...';
    document.getElementById('linkedAccountsTableBody').innerHTML = `
        <tr>
            <td colspan="5" class="px-4 py-12 text-center text-slate-500">Cargando cuentas ligadas...</td>
        </tr>
    `;

    try {
        const response = await fetch(`/api/reportes/comisiones-vendedor/cuentas-ligadas?beneficiaryType=${encodeURIComponent(activeBeneficiaryType)}`);
        const payload = await response.json();

        if (!response.ok || !payload.success) {
            throw new Error(payload.message || payload.error || 'No fue posible obtener las cuentas ligadas.');
        }

        cuentasLigadasActuales = payload.data || [];
        Object.keys(cuentasLigadasSeleccionadas).forEach((key) => delete cuentasLigadasSeleccionadas[key]);
        cuentasLigadasActuales.forEach((beneficiario) => {
            cuentasLigadasSeleccionadas[beneficiario.beneficiarioId] = beneficiario.cuentaLigada?._id || '';
        });

        document.getElementById('linkedAccountsModalCount').textContent = `Se encontraron ${payload.totales?.totalBeneficiarios || cuentasLigadasActuales.length} ${getActiveBeneficiaryPluralLabel()}.`;
        renderLinkedAccountsTable();
    } catch (error) {
        cuentasLigadasActuales = [];
        document.getElementById('linkedAccountsModalCount').textContent = 'No fue posible cargar la configuración';
        document.getElementById('linkedAccountsTableBody').innerHTML = `
            <tr>
                <td colspan="5" class="px-4 py-12 text-center text-rose-600">${escapeHtml(error.message)}</td>
            </tr>
        `;
        showLinkedAccountsMessage(error.message, 'error');
    } finally {
        setLinkedAccountsLoadingState(false);
    }
}

async function guardarCuentaLigada(beneficiarioId) {
    hideLinkedAccountsMessage();
    cuentasLigadasGuardando.add(beneficiarioId);
    renderLinkedAccountsTable();

    try {
        const cuentaId = cuentasLigadasSeleccionadas[beneficiarioId] || '';
        const response = await fetch(`/api/reportes/comisiones-vendedor/cuentas-ligadas/${encodeURIComponent(beneficiarioId)}`, {
            method: 'PUT',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify({
                beneficiaryType: activeBeneficiaryType,
                cuentaId
            })
        });
        const payload = await response.json();

        if (!response.ok || !payload.success) {
            throw new Error(payload.message || payload.error || 'No fue posible guardar la cuenta ligada.');
        }

        const rowIndex = cuentasLigadasActuales.findIndex((beneficiario) => beneficiario.beneficiarioId === beneficiarioId);
        if (rowIndex >= 0) {
            cuentasLigadasActuales[rowIndex] = {
                ...cuentasLigadasActuales[rowIndex],
                ...payload.data
            };
        }

        cuentasLigadasSeleccionadas[beneficiarioId] = payload.data?.cuentaLigada?._id || '';
        syncLinkedAccountWithCurrentReport(payload.data || {});
        renderLinkedAccountsTable();
        showLinkedAccountsMessage(payload.message || 'Cuenta ligada actualizada con éxito.', 'success');
    } catch (error) {
        showLinkedAccountsMessage(error.message, 'error');
    } finally {
        cuentasLigadasGuardando.delete(beneficiarioId);
        renderLinkedAccountsTable();
    }
}

function seleccionarCuenta(vendedorId, cuentaId) {
    cuentasSeleccionadas[vendedorId] = cuentaId;
    renderTable();
}

function toggleDetalle(vendedorId) {
    if (detallesAbiertos.has(vendedorId)) {
        detallesAbiertos.delete(vendedorId);
    } else {
        detallesAbiertos.add(vendedorId);
    }

    renderTable();
}

async function consultarReporteComisiones() {
    hideMessage();
    const dateRange = getDateRangeOrNotify();
    const content = getActiveBeneficiaryContent();

    if (!dateRange) {
        return;
    }

    const { fechaInicio, fechaFin, periodoTexto } = dateRange;

    toggleLoading(true);

    try {
        const response = await fetch(`/api/reportes/comisiones-vendedor?fechaInicio=${fechaInicio}&fechaFin=${fechaFin}&beneficiaryType=${encodeURIComponent(activeBeneficiaryType)}`);
        const payload = await response.json();

        if (!response.ok || !payload.success) {
            throw new Error(payload.message || payload.error || 'No fue posible consultar el reporte.');
        }

        reporteActual = payload.data || [];
        totalesReporteActual = payload.totales || {};
        periodoReporteActual = periodoTexto;
        Object.keys(cuentasSeleccionadas).forEach((key) => delete cuentasSeleccionadas[key]);
        detallesAbiertos.clear();

        reporteActual.forEach((vendedor) => {
            if (vendedor.cuentaDestinoSugerida?._id) {
                cuentasSeleccionadas[vendedor.vendedorId] = vendedor.cuentaDestinoSugerida._id;
            }
        });

        updateSummary(payload.totales || {}, periodoTexto);
        renderTable();

        if (!reporteActual.length) {
            showMessage(content.noRecordsMessage, 'info');
        } else {
            showMessage(content.successMessage(reporteActual.length), 'success');
        }
    } catch (error) {
        reporteActual = [];
        renderTable();
        showMessage(error.message, 'error');
    } finally {
        toggleLoading(false);
    }
}

async function descargarReporteVendedor(vendedorId) {
    hideMessage();
    const dateRange = getDateRangeOrNotify();
    const content = getActiveBeneficiaryContent();
    if (!dateRange) {
        return;
    }

    const { fechaInicio, fechaFin } = dateRange;
    const vendedor = reporteActual.find((item) => item.vendedorId === vendedorId);

    if (!vendedor) {
        showMessage(content.notFoundRowMessage, 'error');
        return;
    }

    try {
        const response = await fetch(`/api/reportes/datos?fechaInicio=${fechaInicio}&fechaFin=${fechaFin}&${content.reportQueryParam}=${encodeURIComponent(vendedorId)}`);

        if (!response.ok) {
            throw new Error(`Error en la respuesta del servidor: ${response.status}`);
        }

        const data = await response.json();

        if (!data.success) {
            throw new Error(data.error || content.reportDownloadError);
        }

        if (!data.data || data.data.length === 0) {
            showMessage(content.noReportMessage(vendedor.vendedorNombre), 'warning');
            return;
        }

        const workbook = buildWorkbookReporteCompleto(data, fechaInicio, fechaFin);
        const blob = workbookToBlob(workbook);
        downloadBlob(blob, content.reportFileName(vendedor.vendedorNombre, fechaInicio, fechaFin));
        showMessage(content.reportDownloadedMessage(vendedor.vendedorNombre), 'success');
    } catch (error) {
        console.error('Error al descargar el reporte individual:', error);
        showMessage(`Error al descargar el reporte individual: ${error.message}`, 'error');
    }
}

async function descargarReportesMasivos() {
    hideMessage();
    const dateRange = getDateRangeOrNotify();
    const content = getActiveBeneficiaryContent();
    if (!dateRange) {
        return;
    }

    if (!reporteActual.length) {
        showMessage(content.bulkDownloadWarning, 'warning');
        return;
    }

    const { fechaInicio, fechaFin } = dateRange;
    const downloadButton = document.getElementById('btnDescargarReporteCompleto');

    downloadButton.disabled = true;
    downloadButton.classList.add('opacity-60', 'cursor-not-allowed');

    try {
        const zip = new JSZip();
        let reportesAgregados = 0;

        for (const vendedor of reporteActual) {
            const response = await fetch(`/api/reportes/datos?fechaInicio=${fechaInicio}&fechaFin=${fechaFin}&${content.reportQueryParam}=${encodeURIComponent(vendedor.vendedorId)}`);

            if (!response.ok) {
                throw new Error(`Error en la descarga de ${vendedor.vendedorNombre}: ${response.status}`);
            }

            const data = await response.json();
            if (!data.success || !data.data || data.data.length === 0) {
                continue;
            }

            const workbook = buildWorkbookReporteCompleto(data, fechaInicio, fechaFin);
            const blob = workbookToBlob(workbook);
            zip.file(content.reportFileName(vendedor.vendedorNombre, fechaInicio, fechaFin), blob);
            reportesAgregados += 1;
        }

        if (!reportesAgregados) {
            showMessage(content.bulkDownloadEmpty, 'warning');
            return;
        }

        const zipBlob = await zip.generateAsync({ type: 'blob' });
        downloadBlob(zipBlob, content.bulkZipName(fechaInicio, fechaFin));
        showMessage(content.bulkDownloadSuccess(reportesAgregados), 'success');
    } catch (error) {
        console.error('Error al descargar los reportes masivos:', error);
        showMessage(`${content.bulkDownloadError}: ${error.message}`, 'error');
    } finally {
        downloadButton.disabled = false;
        downloadButton.classList.remove('opacity-60', 'cursor-not-allowed');
    }
}

function buildWorkbookReporteCompleto(data, fechaInicio, fechaFin) {
    const workbook = XLSX.utils.book_new();

    const categorias = [
        { nombre: 'Identificación', columnas: ['ID Reserva', 'Estatus'], color: 'E7E6E6', colorDatos: 'F2F2F2' },
        { nombre: 'Administración', columnas: ['Admin Cabaña', 'Agente Reserva'], color: 'E7E6E6', colorDatos: 'F2F2F2' },
        { nombre: 'Información de Reserva', columnas: ['Cabaña', 'Agencia', 'Fecha Entrada', 'Fecha Salida', 'Noches', 'Huéspedes'], color: 'FFD966', colorDatos: 'FFF2CC' },
        { nombre: 'Ingresos Base', columnas: ['Precio Base/Noche', 'Ganancia inversionista/Dueño', 'Pago a Dueño', 'Utilidad', 'Limpieza', 'Administrador ligado'], color: '87CEEB', colorDatos: 'D9EDF7' },
        { nombre: 'Comisiones', columnas: ['Admin NyN', 'Comisión Agencia', 'Comisión Gerente', 'Comisión Admin', 'Comisión Vendedor'], color: 'FFA500', colorDatos: 'FFE5CC' },
        { nombre: 'Pagos Cliente', columnas: ['Precio Reserva', 'Total Pagado', 'Pagos Transferencia', 'Pagos Recibió Dueño', 'Pagos Restante', 'Excedente', 'Inversionistas'], color: 'C0C0C0', colorDatos: 'E8E8E8' },
        { nombre: 'Cliente', columnas: ['Cliente', 'Correo', 'Teléfono'], color: 'FFD966', colorDatos: 'FFF2CC' },
        { nombre: 'Observaciones', columnas: ['Notas', 'Notas Privadas'], color: 'E7E6E6', colorDatos: 'F2F2F2' }
    ];

    const worksheetData = [];
    const categoriaRow = [];
    const merges = [];
    let colIndex = 0;

    categorias.forEach((categoria) => {
        const inicio = colIndex;
        const fin = colIndex + categoria.columnas.length - 1;

        categoriaRow.push(categoria.nombre);

        for (let i = 1; i < categoria.columnas.length; i += 1) {
            categoriaRow.push('');
        }

        merges.push({
            s: { r: 0, c: inicio },
            e: { r: 0, c: fin },
            color: categoria.color,
            colorDatos: categoria.colorDatos
        });

        colIndex += categoria.columnas.length;
    });

    const coloresColumnas = [];
    categorias.forEach((categoria) => {
        for (let i = 0; i < categoria.columnas.length; i += 1) {
            coloresColumnas.push(categoria.colorDatos);
        }
    });

    worksheetData.push(categoriaRow);
    worksheetData.push(data.headers.map((header) => header.label));

    data.data.forEach((registro) => {
        const row = data.headers.map((header) => {
            const valor = registro[header.key];

            if (valor === null || valor === undefined) {
                return '';
            }

            if (header.key.includes('fecha') || header.key.includes('Fecha')) {
                return valor;
            }

            if (typeof valor === 'number') {
                return valor;
            }

            return valor;
        });

        worksheetData.push(row);
    });

    const totalesRow = [];
    data.headers.forEach((header, index) => {
        if (index === 0) {
            totalesRow.push('TOTALES');
        } else if (header.key === 'noches') {
            totalesRow.push(data.totales.totalNoches || 0);
        } else if (header.key === 'agencia') {
            totalesRow.push(data.totales.totalAgencia || 0);
        } else if (header.key === 'precioReserva') {
            totalesRow.push(data.totales.totalPrecioReservas || 0);
        } else if (header.key === 'administracionNyN') {
            totalesRow.push(data.totales.totalComisionSistema || 0);
        } else if (header.key === 'comisionAgencia') {
            totalesRow.push(data.totales.totalComisionAgencia || 0);
        } else if (header.key === 'comisionAdminCabana') {
            totalesRow.push(data.totales.totalComisionAdmin || 0);
        } else if (header.key === 'comisionVendedor') {
            totalesRow.push(data.totales.totalComisionVendedor || 0);
        } else if (header.key === 'pagoADueno') {
            totalesRow.push(data.totales.totalPagoADueno || 0);
        } else if (header.key === 'utilidadTotal') {
            totalesRow.push(data.totales.totalUtilidades || 0);
        } else if (header.key === 'totalPagado') {
            totalesRow.push(data.totales.totalIngresos || 0);
        } else if (header.key === 'pagosTransferencia') {
            totalesRow.push(data.totales.totalPagosTransferencia || 0);
        } else if (header.key === 'pagosRecibioDueno') {
            totalesRow.push(data.totales.totalPagosRecibioDueno || 0);
        } else if (header.key === 'pagosRestante') {
            totalesRow.push(data.totales.totalPagosRestante || 0);
        } else if (header.key === 'excedente') {
            totalesRow.push(data.totales.totalExcedente || 0);
        } else {
            totalesRow.push('');
        }
    });

    worksheetData.push(totalesRow);

    const worksheet = XLSX.utils.aoa_to_sheet(worksheetData);
    worksheet['!cols'] = data.headers.map((header) => ({ wch: header.width || 15 }));

    const range = XLSX.utils.decode_range(worksheet['!ref']);
    const columnasMonetarias = [
        'precioBasePorNoche', 'precioBase', 'pagoADueno', 'precioReserva', 'limpieza',
        'participacionBosques', 'administracionNyN', 'comisionAgencia', 'comisionAdminCabana',
        'comisionGerente', 'comisionVendedor', 'utilidadTotal',
        'comisionInversionistas', 'comisionDueno', 'totalPagado',
        'pagosTransferencia', 'pagosRecibioDueno', 'pagosRestante',
        'pagosNoEfectivo', 'liquidaEfectivo', 'excedente', 'balanceDue', 'agencia'
    ];

    const indicesMonetarios = data.headers
        .map((header, idx) => (columnasMonetarias.includes(header.key) ? idx : -1))
        .filter((idx) => idx !== -1);

    for (let row = range.s.r; row <= range.e.r; row += 1) {
        for (let col = range.s.c; col <= range.e.c; col += 1) {
            const cellAddress = XLSX.utils.encode_cell({ r: row, c: col });

            if (!worksheet[cellAddress]) {
                worksheet[cellAddress] = { t: 's', v: '' };
            }

            if (row === 0) {
                const merge = merges.find((item) => col >= item.s.c && col <= item.e.c);
                const colorCategoria = merge ? merge.color : 'E7E6E6';

                worksheet[cellAddress].s = {
                    font: { bold: true, sz: 11, color: { rgb: '000000' } },
                    fill: { fgColor: { rgb: colorCategoria } },
                    alignment: { horizontal: 'center', vertical: 'center' },
                    border: {
                        top: { style: 'medium', color: { rgb: '000000' } },
                        bottom: { style: 'medium', color: { rgb: '000000' } },
                        left: { style: 'medium', color: { rgb: '000000' } },
                        right: { style: 'medium', color: { rgb: '000000' } }
                    }
                };
            } else if (row === 1) {
                worksheet[cellAddress].s = {
                    font: { bold: true, color: { rgb: 'FFFFFF' } },
                    fill: { fgColor: { rgb: '4B5563' } },
                    alignment: { horizontal: 'center', vertical: 'center' },
                    border: {
                        top: { style: 'thin', color: { rgb: '000000' } },
                        bottom: { style: 'thin', color: { rgb: '000000' } },
                        left: { style: 'thin', color: { rgb: '000000' } },
                        right: { style: 'thin', color: { rgb: '000000' } }
                    }
                };
            } else if (row === range.e.r) {
                worksheet[cellAddress].s = {
                    font: { bold: true },
                    fill: { fgColor: { rgb: 'FEF3C7' } },
                    alignment: {
                        horizontal: indicesMonetarios.includes(col) ? 'right' : 'left',
                        vertical: 'center'
                    },
                    border: {
                        top: { style: 'thin', color: { rgb: '000000' } },
                        bottom: { style: 'thin', color: { rgb: '000000' } },
                        left: { style: 'thin', color: { rgb: '000000' } },
                        right: { style: 'thin', color: { rgb: '000000' } }
                    }
                };

                if (indicesMonetarios.includes(col) && typeof worksheet[cellAddress].v === 'number') {
                    worksheet[cellAddress].z = '$#,##0.00';
                }
            } else {
                const colorColumna = coloresColumnas[col] || 'FFFFFF';

                worksheet[cellAddress].s = {
                    fill: { fgColor: { rgb: colorColumna } },
                    alignment: {
                        horizontal: indicesMonetarios.includes(col) ? 'right' : 'left',
                        vertical: 'center'
                    },
                    border: {
                        top: { style: 'thin', color: { rgb: 'E5E7EB' } },
                        bottom: { style: 'thin', color: { rgb: 'E5E7EB' } },
                        left: { style: 'thin', color: { rgb: 'E5E7EB' } },
                        right: { style: 'thin', color: { rgb: 'E5E7EB' } }
                    }
                };

                if (indicesMonetarios.includes(col) && typeof worksheet[cellAddress].v === 'number') {
                    worksheet[cellAddress].z = '$#,##0.00';
                }
            }
        }
    }

    worksheet['!merges'] = merges.map((merge) => ({
        s: { r: merge.s.r, c: merge.s.c },
        e: { r: merge.e.r, c: merge.e.c }
    }));

    XLSX.utils.book_append_sheet(workbook, worksheet, 'Reporte');

    const metadataData = [
        ['INFORMACIÓN DEL REPORTE'],
        [],
        ['Rango de fechas:', `${fechaInicio} - ${fechaFin}`],
        ['Fecha de generación:', data.metadata.fechaGeneracion],
        ['Total de registros:', data.metadata.totalRegistros],
        [],
        ['TOTALES GENERALES'],
        [],
        ['Total Reservas:', data.totales.totalReservas],
        ['Total Noches:', data.totales.totalNoches],
        ['Total Ingresos:', data.totales.totalIngresos],
        ['Total Precio Reservas:', data.totales.totalPrecioReservas],
        ['Total Comisión Sistema:', data.totales.totalComisionSistema],
        ['Total Comisión Admin:', data.totales.totalComisionAdmin],
        ['Total Comisión Vendedor:', data.totales.totalComisionVendedor],
        ['Total Utilidades:', data.totales.totalUtilidades],
        ['Total Excedente:', data.totales.totalExcedente]
    ];

    const metadataSheet = XLSX.utils.aoa_to_sheet(metadataData);
    metadataSheet['!cols'] = [{ wch: 30 }, { wch: 30 }];

    if (metadataSheet.A1) {
        metadataSheet.A1.s = {
            font: { bold: true, sz: 14 },
            fill: { fgColor: { rgb: '4B5563' } },
            alignment: { horizontal: 'center' }
        };
    }

    if (metadataSheet.A7) {
        metadataSheet.A7.s = {
            font: { bold: true, sz: 12 },
            fill: { fgColor: { rgb: '9CA3AF' } }
        };
    }

    ['B11', 'B12', 'B13', 'B14', 'B15', 'B16', 'B17', 'B18'].forEach((cell) => {
        if (metadataSheet[cell] && typeof metadataSheet[cell].v === 'number') {
            metadataSheet[cell].z = '$#,##0.00';
        }
    });

    XLSX.utils.book_append_sheet(workbook, metadataSheet, 'Metadata');
    return workbook;
}

async function crearSolicitudFinanzas(vendedorId) {
    const vendedor = reporteActual.find((item) => item.vendedorId === vendedorId);
    const dateRange = getDateRangeOrNotify();
    const cuentaId = cuentasSeleccionadas[vendedorId] || vendedor?.cuentaDestinoSugerida?._id;
    const content = getActiveBeneficiaryContent();

    if (!dateRange) {
        return;
    }

    const { fechaInicio, fechaFin } = dateRange;

    if (!vendedor) {
        showMessage(content.notFoundRowMessage, 'error');
        return;
    }

    if (!cuentaId) {
        showMessage(content.requestNoAccount(vendedor.vendedorNombre), 'warning');
        return;
    }

    if (Number(vendedor.totalComisionesPagables || 0) <= 0) {
        showMessage(content.requestNoPayable(vendedor.vendedorNombre), 'warning');
        return;
    }

    try {
        hideMessage();

        const response = await fetch('/api/reportes/comisiones-vendedor/solicitudes', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify({
                fechaInicio,
                fechaFin,
                beneficiaryType: activeBeneficiaryType,
                beneficiarioId: vendedorId,
                vendedorId,
                cuentaId
            })
        });

        const payload = await response.json();

        if (!response.ok || !payload.success) {
            throw new Error(payload.message || payload.error || 'No fue posible crear la solicitud.');
        }

        vendedor.solicitudCreada = true;
        renderTable();
        showMessage(content.requestSuccess(vendedor.vendedorNombre), 'success');
    } catch (error) {
        showMessage(error.message, 'error');
    }
}

function limpiarFiltrosComisiones() {
    setDefaultDates();
    resetCurrentReport();
    renderTable();
    hideMessage();
}

document.addEventListener('DOMContentLoaded', () => {
    setDefaultDates();
    updateBeneficiaryTypeUI();
    renderTable();

    document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape' && isLinkedAccountsModalOpen()) {
            closeLinkedAccountsModal();
        }
    });
});
