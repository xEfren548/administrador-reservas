<!-- Modal: Crear/Editar Cupón -->
<div class="modal fade" id="modalCupon" tabindex="-1" aria-labelledby="modalCuponLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalCuponLabel">Nuevo Cupón</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="form-cupon">
                    <input type="hidden" id="cupon-id">
                    
                    <div class="row">
                        <!-- Información Básica -->
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Nombre del Cupón *</label>
                            <input type="text" id="cupon-nombre" class="form-control" required>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label">Código *</label>
                            <input type="text" id="cupon-codigo" class="form-control" required style="text-transform: uppercase;">
                            <small class="text-muted">Se convertirá a mayúsculas automáticamente</small>
                        </div>

                        <div class="col-md-4 mb-3">
                            <label class="form-label">Tipo de Descuento *</label>
                            <select id="cupon-tipo" class="form-select" required>
                                <option value="percentage">Porcentaje (%)</option>
                                <option value="fixed_amount">Monto Fijo ($)</option>
                                <option value="nights_free">Noches Gratis</option>
                            </select>
                        </div>

                        <div class="col-md-4 mb-3">
                            <label class="form-label">Valor *</label>
                            <input type="number" id="cupon-valor" class="form-control" min="0" step="0.01" required>
                            <small id="valor-help" class="text-muted">Porcentaje: 1-100</small>
                        </div>

                        <div class="col-md-4 mb-3" id="campo-noches-recibidas" style="display: none;">
                            <label class="form-label">Noches Recibidas *</label>
                            <input type="number" id="cupon-noches-recibidas" class="form-control" min="1" step="1" placeholder="Ej: 3">
                            <small class="text-muted">Total de noches</small>
                        </div>

                        <div class="col-md-4 mb-3" id="campo-noches-pagadas" style="display: none;">
                            <label class="form-label">Noches que se Pagan *</label>
                            <input type="number" id="cupon-noches-pagadas" class="form-control" min="1" step="1" placeholder="Ej: 2">
                            <small class="text-muted">Noches a cobrar</small>
                        </div>

                        <div class="col-md-4 mb-3">
                            <label class="form-label">Aplica a *</label>
                            <select id="cupon-aplicable-a" class="form-select" required>
                                <option value="all">Todos</option>
                                <option value="owner_only">Solo Dueño</option>
                                <option value="except_owner">Excepto Dueño</option>
                                <option value="virtual_seller">Vendedor Virtual (Web)</option>
                            </select>
                        </div>

                        <div class="col-12 mb-3">
                            <div class="form-check">
                                <input type="checkbox" id="cupon-es-web" class="form-check-input">
                                <label class="form-check-label" for="cupon-es-web">
                                    Es cupón web (solo válido para reservas web)
                                </label>
                            </div>
                        </div>

                        <!-- Advertencia para Noches Gratis + Excepto Dueño -->
                        <div class="col-12 mb-3" id="warning-noches-except-owner" style="display: none;">
                            <div class="alert alert-warning d-flex align-items-start" role="alert">
                                <i class="fas fa-exclamation-triangle me-2 mt-1"></i>
                                <div>
                                    <strong>⚠️ Advertencia:</strong> 
                                    Al combinar <strong>"Noches Gratis"</strong> con <strong>"Excepto Dueño"</strong>, 
                                    revise cuidadosamente el monto del descuento y realice los cálculos correctamente. 
                                    Si el monto de descuento es mayor a las utilidades disponibles (utilidad + comisiones), 
                                    se generarán <strong>utilidades negativas</strong>.
                                </div>
                            </div>
                        </div>

                        <!-- Fechas de Vigencia -->
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Fecha de Inicio *</label>
                            <input type="date" id="cupon-fecha-inicio" class="form-control" required>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label">Fecha de Fin *</label>
                            <input type="date" id="cupon-fecha-fin" class="form-control" required>
                        </div>

                        <!-- Límites -->
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Usos Limitados</label>
                            <input type="number" id="cupon-usos-limitados" class="form-control" min="1" placeholder="Dejar vacío para ilimitado">
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label">Monto Mínimo de Compra</label>
                            <input type="number" id="cupon-monto-minimo" class="form-control" min="0" step="0.01" value="0">
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label">Descuento Máximo</label>
                            <input type="number" id="cupon-descuento-maximo" class="form-control" min="0" step="0.01" placeholder="Sin límite">
                        </div>

                        <!-- Habitaciones -->
                        <div class="col-12 mb-3">
                            <div class="form-check">
                                <input type="checkbox" id="cupon-todas-cabanas" class="form-check-input" checked>
                                <label class="form-check-label" for="cupon-todas-cabanas">
                                    Aplicable a todas las cabañas
                                </label>
                            </div>
                        </div>

                        <div class="col-12 mb-3" id="selector-habitaciones" style="display: none;">
                            <label class="form-label">Seleccionar Habitaciones</label>
                            <input type="text" id="buscar-habitaciones-cupon" class="form-control mb-2" placeholder="🔍 Buscar habitaciones...">
                            <div id="cupon-habitaciones-list" style="max-height: 300px; overflow-y: auto; border: 1px solid #dee2e6; border-radius: 0.25rem; padding: 0.75rem; background-color: #f8f9fa;">
                                <!-- Se llena dinámicamente -->
                            </div>
                            <small class="text-muted" id="habitaciones-selected-count-cupon">0 habitaciones seleccionadas</small>
                        </div>

                        <!-- Restricciones -->
                        <div class="col-12 mb-3">
                            <h6 class="text-muted">Restricciones (Opcional)</h6>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label">Noches Mínimas</label>
                            <input type="number" id="cupon-noches-minimas" class="form-control" min="1" placeholder="Sin restricción">
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label">Noches Máximas</label>
                            <input type="number" id="cupon-noches-maximas" class="form-control" min="1" placeholder="Sin restricción">
                        </div>

                        <!-- Descripción -->
                        <div class="col-12 mb-3">
                            <label class="form-label">Descripción</label>
                            <textarea id="cupon-descripcion" class="form-control" rows="3" maxlength="500"></textarea>
                            <small class="text-muted">Máximo 500 caracteres</small>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" id="btn-guardar-cupon" class="btn btn-primary">Guardar Cupón</button>
