<!-- Modal: Nueva Cuenta de Referido -->
<div class="modal fade" id="modalCuentaReferido" tabindex="-1" aria-labelledby="modalCuentaReferidoLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalCuentaReferidoLabel">Nueva Cuenta de Referido</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="form-cuenta-referido">
                    <input type="hidden" id="cuenta-id">
                    
                    <!-- Sección: Información de la Cuenta -->
                    <h6 class="mb-3 text-purple-600 font-semibold">Información de la Cuenta</h6>
                    <div class="row mb-4">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Nombre *</label>
                            <input type="text" id="cuenta-nombre" class="form-control" required maxlength="100">
                        </div>

                        <div class="col-md-3 mb-3">
                            <label class="form-label">Celular</label>
                            <input type="text" id="cuenta-celular" class="form-control" maxlength="20">
                        </div>

                        <div class="col-md-3 mb-3">
                            <label class="form-label">Tipo *</label>
                            <select id="cuenta-tipo" class="form-select" required>
                                <option value="influencer">Influencer</option>
                                <option value="marca">Marca</option>
                                <option value="afiliado">Afiliado</option>
                                <option value="otro">Otro</option>
                            </select>
                        </div>

                        <div class="col-12 mb-3">
                            <label class="form-label">Notas</label>
                            <textarea id="cuenta-notas" class="form-control" rows="2" maxlength="500"></textarea>
                            <small class="text-muted">Máximo 500 caracteres</small>
                        </div>
                    </div>

                    <!-- Sección: Configuración de Comisión -->
                    <h6 class="mb-3 text-purple-600 font-semibold">Configuración de Comisión del Referidor</h6>
                    <div class="row mb-4">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Tipo de Comisión *</label>
                            <select id="comision-tipo" class="form-select" required>
                                <option value="percentage">Porcentaje del Monto Original</option>
                                <option value="fixed_amount">Monto Fijo por Uso</option>
                            </select>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label">Valor *</label>
                            <input type="number" id="comision-valor" class="form-control" required min="0" step="0.01">
                            <small id="comision-hint" class="text-muted">Ejemplo: 10 para 10% o $100 por uso</small>
                        </div>
                    </div>

                    <!-- Sección: Datos del Cupón -->
                    <h6 class="mb-3 text-purple-600 font-semibold">Cupón Asociado</h6>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Código del Cupón *</label>
                            <input type="text" id="cupon-referido-codigo" class="form-control" required style="text-transform: uppercase;">
                            <small class="text-muted">Se convertirá a mayúsculas automáticamente</small>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label">Nombre del Cupón *</label>
                            <input type="text" id="cupon-referido-nombre" class="form-control" required>
                        </div>

                        <div class="col-md-4 mb-3">
                            <label class="form-label">Tipo de Descuento *</label>
                            <select id="cupon-referido-tipo" class="form-select" required>
                                <option value="percentage">Porcentaje (%)</option>
                                <option value="fixed_amount">Monto Fijo ($)</option>
                                <option value="nights_free">Noches Gratis (3x2)</option>
                            </select>
                        </div>

                        <div class="col-md-4 mb-3">
                            <label class="form-label">Valor *</label>
                            <input type="number" id="cupon-referido-valor" class="form-control" required min="0" step="0.01">
                            <small id="valor-help-referido" class="text-muted">Porcentaje: 1-100</small>
                        </div>

                        <div class="col-md-4 mb-3" id="campo-noches-recibidas-referido" style="display: none;">
                            <label class="form-label">Noches Recibidas *</label>
                            <input type="number" id="cupon-referido-noches-recibidas" class="form-control" min="1" step="1" placeholder="Ej: 3">
                            <small class="text-muted">Total de noches</small>
                        </div>

                        <div class="col-md-4 mb-3" id="campo-noches-pagadas-referido" style="display: none;">
                            <label class="form-label">Noches que se Pagan *</label>
                            <input type="number" id="cupon-referido-noches-pagadas" class="form-control" min="1" step="1" placeholder="Ej: 2">
                            <small class="text-muted">Noches a cobrar</small>
                        </div>

                        <div class="col-md-4 mb-3">
                            <label class="form-label">Aplica a *</label>
                            <select id="cupon-referido-aplicable" class="form-select" required disabled>
                                <option value="virtual_seller" selected>Vendedor Virtual (Web)</option>
                            </select>
                            <small class="text-muted">Los cupones de referido se aplican automáticamente al vendedor virtual.</small>
                        </div>

                        <!-- Advertencia para Noches Gratis + Excepto Dueño -->
                        <div class="col-12 mb-3" id="warning-noches-except-owner-referido" style="display: none;">
                            <div class="alert alert-warning d-flex align-items-start" role="alert">
                                <i class="fas fa-exclamation-triangle me-2 mt-1"></i>
                                <div>
                                    <strong>⚠️ Advertencia:</strong> 
                                    Al combinar <strong>"Noches Gratis"</strong> con <strong>"Excepto Dueño"</strong>, 
                                    revise cuidadosamente el monto del descuento y realice los cálculos correctamente. 
                                    Si el monto de descuento es mayor a las utilidades disponibles (utilidad + comisiones), 
                                    se generarán <strong>utilidades negativas</strong>.
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label">Fecha Inicio *</label>
                            <input type="date" id="cupon-referido-fecha-inicio" class="form-control" required>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label">Fecha Fin *</label>
                            <input type="date" id="cupon-referido-fecha-fin" class="form-control" required>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label">Usos Limitados</label>
                            <input type="number" id="cupon-referido-usos" class="form-control" min="1" placeholder="Dejar vacío para ilimitado">
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label">Monto Mínimo de Compra</label>
                            <input type="number" id="cupon-referido-monto-min" class="form-control" min="0" step="0.01" value="0">
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label">Descuento Máximo</label>
                            <input type="number" id="cupon-referido-descuento-max" class="form-control" min="0" step="0.01" placeholder="Sin límite">
                        </div>

                        <!-- Habitaciones -->
                        <div class="col-12 mb-3">
                            <div class="form-check">
                                <input type="checkbox" id="cupon-referido-todas-cabanas" class="form-check-input" checked>
                                <label class="form-check-label" for="cupon-referido-todas-cabanas">
                                    Aplicable a todas las cabañas
                                </label>
                            </div>
                        </div>

                        <div class="col-12 mb-3" id="selector-habitaciones-referido" style="display: none;">
                            <label class="form-label">Seleccionar Habitaciones</label>
                            <input type="text" id="buscar-habitaciones-referido" class="form-control mb-2" placeholder="🔍 Buscar habitaciones...">
                            <div id="cupon-referido-habitaciones-list" style="max-height: 300px; overflow-y: auto; border: 1px solid #dee2e6; border-radius: 0.25rem; padding: 0.75rem; background-color: #f8f9fa;">
                                <!-- Se llena dinámicamente -->
                            </div>
                            <small class="text-muted" id="habitaciones-selected-count-referido">0 habitaciones seleccionadas</small>
                        </div>

                        <!-- Restricciones -->
                        <div class="col-12 mb-3">
                            <h6 class="text-muted">Restricciones (Opcional)</h6>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label">Noches Mínimas</label>
                            <input type="number" id="cupon-referido-noches-minimas" class="form-control" min="1" placeholder="Sin restricción">
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label">Noches Máximas</label>
                            <input type="number" id="cupon-referido-noches-maximas" class="form-control" min="1" placeholder="Sin restricción">
                        </div>

                        <div class="col-12 mb-3">
                            <label class="form-label">Descripción</label>
                            <textarea id="cupon-referido-descripcion" class="form-control" rows="3" maxlength="500"></textarea>
                            <small class="text-muted">Máximo 500 caracteres</small>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" id="btn-guardar-cuenta-referido" class="btn btn-primary">
                    <i class="fas fa-save me-1"></i> Crear Cuenta y Cupón
                </button>
            </div>
        </div>
    </div>
</div>

